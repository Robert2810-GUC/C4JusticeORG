@model C4Justice.Web.Models.SiteEvent
@{ ViewData["Title"] = "Add New Event"; }

<div style="max-width:680px">
    <div class="page-header">
        <div>
            <div class="page-title">Add New Event</div>
            <div class="page-sub">Create a new community event for the website</div>
        </div>
        <a href="/Admin/Events" style="background:#f0f4ff;color:#0d1f3c;border:1.5px solid #dde;padding:8px 16px;border-radius:4px;font-size:12px;font-weight:700;font-family:Arial;text-decoration:none">← Back to Events</a>
    </div>

    <div class="form-preview">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Event Title *</label>
                <input asp-for="Title" placeholder="e.g. Community Town Hall Meeting" required />
                <span asp-validation-for="Title" style="color:#e74c3c;font-size:11px;font-family:Arial"></span>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Start Date *</label>
                    <input asp-for="EventDate" type="date" required />
                    <span asp-validation-for="EventDate" style="color:#e74c3c;font-size:11px;font-family:Arial"></span>
                </div>
                <div class="form-group">
                    <label>End Date <span style="color:#aaa;font-weight:400">(optional)</span></label>
                    <input asp-for="EndDate" type="date" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Location</label>
                    <input asp-for="Location" placeholder="Venue name and address" />
                </div>
                <div class="form-group">
                    <label>Category</label>
                    <select asp-for="Category">
                        <option value="Town Halls">Town Halls</option>
                        <option value="Voter Registration">Voter Registration</option>
                        <option value="Healthcare">Healthcare</option>
                        <option value="Environmental">Environmental</option>
                        <option value="Election Cycles">Election Cycles</option>
                        <option value="Political">Political</option>
                        <option value="General">General</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Description * <span id="desc-count" style="float:right;color:#aaa;font-weight:400">0 / 300</span></label>
                <textarea asp-for="Description" maxlength="300" oninput="updateCount(this)" placeholder="Describe this event..." required></textarea>
                <span asp-validation-for="Description" style="color:#e74c3c;font-size:11px;font-family:Arial"></span>
            </div>
            <div class="form-group">
                <label>Registration URL <span style="color:#aaa;font-weight:400">(optional)</span></label>
                <input asp-for="RegisterUrl" type="url" placeholder="https://..." />
            </div>
            <div style="display:flex;gap:20px;margin-bottom:16px;padding:12px;background:#f8faff;border-radius:4px;border:1px solid #eef">
                <div style="display:flex;align-items:center;gap:8px">
                    <input asp-for="IsActive" type="checkbox" style="width:16px;height:16px;accent-color:#0d1f3c" />
                    <label style="font-size:12px;color:#555;font-family:Arial;font-weight:600;cursor:pointer">Active — visible on the public site</label>
                </div>
                <div style="display:flex;align-items:center;gap:8px">
                    <input asp-for="IsCompleted" type="checkbox" style="width:16px;height:16px;accent-color:#c0392b" />
                    <label style="font-size:12px;color:#c0392b;font-family:Arial;font-weight:600;cursor:pointer">Mark as Completed — removes from public site</label>
                </div>
            </div>
            <div style="display:flex;gap:8px">
                <a href="/Admin/Events" class="submit-btn dark" style="flex:1;text-align:center;text-decoration:none;padding:9px;display:block">Cancel</a>
                <button type="submit" class="submit-btn" style="flex:2">Publish Event</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function updateCount(el) {
    document.getElementById('desc-count').textContent = el.value.length + ' / ' + el.maxLength;
}
// Auto-set end date min to start date
document.querySelector('input[type="date"]').addEventListener('change', function() {
    var endInput = document.querySelectorAll('input[type="date"]')[1];
    if (endInput && (!endInput.value || endInput.value < this.value)) endInput.min = this.value;
});
</script>
}
