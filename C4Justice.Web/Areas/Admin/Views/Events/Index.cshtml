@model IEnumerable<C4Justice.Web.Models.SiteEvent>
@{
    ViewData["Title"] = "Events";
    var today = DateTime.UtcNow.Date;
    var upcoming  = Model.Count(e => e.IsActive && !e.IsCompleted && (e.EndDate.HasValue ? e.EndDate.Value.Date >= today : e.EventDate.Date >= today));
    var thisWeek  = Model.Count(e => e.IsActive && !e.IsCompleted && e.EventDate.Date >= today && e.EventDate.Date <= today.AddDays(7));
    var completed = Model.Count(e => e.IsCompleted);
    var expired   = Model.Count(e => !e.IsCompleted && (e.EndDate.HasValue ? e.EndDate.Value.Date < today : e.EventDate.Date < today));
    var total     = Model.Count();
}

@section TopbarActions {
    <a href="/Admin/Events/Create" class="view-site-btn" style="background:#e8c84a;color:#0d1f3c">+ Add Event</a>
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div>
        <div class="page-title">Events Management</div>
        <div class="page-sub">Create, publish, and manage community events</div>
    </div>
</div>

<!-- MINI STATS -->
<div class="mini-stats">
    <div class="mini-stat blue">
        <div class="num">@upcoming</div>
        <div class="lbl">Upcoming Events</div>
    </div>
    <div class="mini-stat">
        <div class="num">@thisWeek</div>
        <div class="lbl">This Week</div>
    </div>
    <div class="mini-stat green">
        <div class="num">@total</div>
        <div class="lbl">Total This Year</div>
    </div>
    <div class="mini-stat red">
        <div class="num">@expired</div>
        <div class="lbl">Auto-Expired</div>
    </div>
    <div class="mini-stat purple">
        <div class="num">@completed</div>
        <div class="lbl">Completed</div>
    </div>
</div>

<!-- AUTO EXPIRY NOTICE -->
<div class="warning-banner">
    ⚡ <strong>Auto-Expiry:</strong> Events are automatically marked as expired after their event date passes. Expired events remain visible in this admin panel but are hidden from the public site.
</div>

<!-- FILTER BAR -->
<div class="filter-bar">
    <button class="filter-btn active" onclick="filterEvents('all',this)">All Events</button>
    <button class="filter-btn" onclick="filterEvents('upcoming',this)">Upcoming</button>
    <button class="filter-btn" onclick="filterEvents('thisweek',this)">This Week</button>
    <button class="filter-btn" onclick="filterEvents('expired',this)">Expired</button>
    <button class="filter-btn" onclick="filterEvents('completed',this)">Completed</button>
</div>

<div style="display:grid;grid-template-columns:1fr 360px;gap:20px;align-items:start">
    <!-- EVENTS TABLE -->
    <div class="table-card" style="margin-bottom:0">
        <!-- Table Header -->
        <div style="background:#0d1f3c;display:grid;grid-template-columns:2fr 1fr 1fr 1fr 100px;padding:10px 16px;gap:12px">
            <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Event</div>
            <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Date</div>
            <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Category</div>
            <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Status</div>
            <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Actions</div>
        </div>
        @foreach (var e in Model.OrderByDescending(ev => ev.EventDate))
        {
            var endD      = e.EndDate?.Date ?? e.EventDate.Date;
            var isExpired = !e.IsCompleted && endD < today;
            var isThisWeek = !isExpired && !e.IsCompleted && e.EventDate.Date >= today && e.EventDate.Date <= today.AddDays(7);
            var statusFilter = e.IsCompleted ? "completed" : isExpired ? "expired" : isThisWeek ? "thisweek" : "upcoming";
            <div class="event-row @(isExpired || e.IsCompleted ? "expired-row" : "")" data-filter="@statusFilter">
                <div>
                    <div class="event-name">@e.Title</div>
                    <div class="event-location">@(e.Location ?? "TBD")</div>
                    <span class="event-category @(e.Category == "Voter Registration" ? "voter" : e.Category == "Healthcare" ? "health" : e.Category == "Environmental" ? "env" : "")">@(e.Category ?? "General")</span>
                </div>
                <div>
                    <div class="event-date">@e.EventDate.ToString("MMM d, yyyy")</div>
                    @if (e.EndDate.HasValue)
                    {
                        <div class="event-date-sub">→ @e.EndDate.Value.ToString("MMM d, yyyy")</div>
                    }
                </div>
                <div></div>
                <div>
                    @if (e.IsCompleted) { <span class="badge" style="background:#f0e6ff;color:#6c3483;font-weight:700">Completed</span> }
                    else if (isExpired) { <span class="badge expired">Expired</span> }
                    else if (isThisWeek) { <span class="badge pending">This Week</span> }
                    else { <span class="badge upcoming">Upcoming</span> }
                    @if (!e.IsActive) { <br/><span class="badge" style="background:#f5f5f5;color:#999;margin-top:3px">Hidden</span> }
                </div>
                <div class="row-actions">
                    <a href="/Admin/Events/Edit/@e.Id" class="act-btn edit">Edit</a>
                    <form method="post" action="/Admin/Events/Delete/@e.Id" style="display:inline" onsubmit="return confirm('Delete this event?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="act-btn del">Del</button>
                    </form>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div style="text-align:center;padding:40px;color:#aaa;font-family:Arial">No events yet. Click "+ Add Event" to get started.</div>
        }
    </div>

    <!-- ADD EVENT FORM -->
    <div id="event-form-panel">
        <div class="section-title" id="form-title">Add New Event</div>
        <div class="form-preview">
            <form method="post" action="/Admin/Events/Create" id="event-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="IsActive" value="true" />
                <div class="form-group">
                    <label>Event Title</label>
                    <input type="text" name="Title" placeholder="e.g. Community Town Hall Meeting" required />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Start Date</label>
                        <input type="date" name="EventDate" required />
                    </div>
                    <div class="form-group">
                        <label>End Date <span style="color:#aaa;font-weight:400">(opt)</span></label>
                        <input type="date" name="EndDate" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Location</label>
                        <input type="text" name="Location" placeholder="Venue or address" />
                    </div>
                    <div class="form-group">
                        <label>Category</label>
                        <select name="Category">
                            <option value="Town Halls">Town Halls</option>
                            <option value="Voter Registration">Voter Registration</option>
                            <option value="Healthcare">Healthcare</option>
                            <option value="Environmental">Environmental</option>
                            <option value="Election Cycles">Election Cycles</option>
                            <option value="Political">Political</option>
                            <option value="General">General</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>Description <span id="desc-count" style="float:right;color:#aaa;font-weight:400">0 / 300</span></label>
                    <textarea name="Description" maxlength="300" oninput="updateCount(this)" placeholder="Brief event description..."></textarea>
                </div>
                <div class="form-group">
                    <label>Registration URL (optional)</label>
                    <input type="url" name="RegisterUrl" placeholder="https://..." />
                </div>
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;padding:10px;background:#fff8f8;border-radius:4px;border:1px solid #f5e6e6">
                    <input type="checkbox" name="IsCompleted" value="true" id="qs-completed" style="width:15px;height:15px;accent-color:#c0392b" />
                    <label for="qs-completed" style="font-size:11px;color:#c0392b;font-family:Arial;font-weight:600;cursor:pointer;margin:0">Mark as Completed — hides from public site</label>
                </div>
                <div style="display:flex;gap:8px">
                    <button type="button" onclick="clearForm()" class="submit-btn dark" style="flex:1">Clear</button>
                    <button type="submit" class="submit-btn" style="flex:2">Publish Event</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
<style>
.event-row{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 100px;padding:14px 16px;gap:12px;align-items:center;border-bottom:.5px solid #f0f0f0;transition:background .15s}
.event-row:last-child{border-bottom:none}
.event-row:hover{background:#fafbff}
.event-row.expired-row{opacity:.65}
.event-name{font-size:13px;font-weight:700;color:#0d1f3c;font-family:Arial}
.event-location{font-size:11px;color:#999;font-family:Arial;margin-top:2px}
.event-category{display:inline-block;font-size:10px;background:#e8f0ff;color:#0d1f3c;padding:2px 8px;border-radius:3px;font-family:Arial;font-weight:600;margin-top:4px}
.event-category.voter{background:#e8f5e9;color:#1b5e20}
.event-category.health{background:#fce4ec;color:#880e4f}
.event-category.env{background:#e0f7fa;color:#006064}
.event-date{font-size:12px;font-family:Arial;color:#333;font-weight:600}
.event-date-sub{font-size:10px;color:#aaa;font-family:Arial;margin-top:2px}
.row-actions{display:flex;gap:5px;flex-wrap:wrap}
.act-btn{font-size:10px;padding:4px 9px;border-radius:3px;border:none;cursor:pointer;font-family:Arial;font-weight:600}
.act-btn.edit{background:#e8f0ff;color:#0d1f3c}
.act-btn.edit:hover{background:#d0e0ff}
.act-btn.del{background:#ffeaea;color:#c0392b}
.act-btn.del:hover{background:#ffcdcd}
</style>
}

@section Scripts {
<script>
function filterEvents(type, btn) {
    document.querySelectorAll('.filter-btn').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
    document.querySelectorAll('.event-row').forEach(function(row) {
        if (type === 'all') row.style.display = '';
        else row.style.display = row.dataset.filter === type ? '' : 'none';
    });
}
function updateCount(el) {
    document.getElementById('desc-count').textContent = el.value.length + ' / ' + el.maxLength;
}
function clearForm() {
    document.getElementById('event-form').reset();
    document.getElementById('desc-count').textContent = '0 / 300';
}
</script>
}
