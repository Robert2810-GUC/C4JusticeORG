@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
    var _rcSiteKey = (ViewBag.RecaptchaSiteKey as string) ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="~/images/c4TitleLOGO.png">
    <title>Admin Login — CU4J</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:'Georgia',serif;background:#f0f2f7;min-height:100vh;display:flex;align-items:center;justify-content:center}
        .login-wrap{width:100%;max-width:420px;padding:20px}
        .login-card{background:#fff;border-radius:8px;padding:40px 36px;box-shadow:0 4px 24px rgba(13,31,60,.12)}
        .login-logo-wrap{text-align:center;margin-bottom:28px}
        .login-logo-circle{width:64px;height:64px;border-radius:50%;border:2px solid #e8c84a;overflow:hidden;display:inline-block;margin-bottom:12px;background:#0d1f3c}
        .login-logo-circle img{width:100%;height:100%;object-fit:cover;display:block}
        .login-title{font-size:20px;font-weight:700;color:#0d1f3c}
        .login-sub{font-size:12px;color:#888;font-family:Arial,sans-serif;margin-top:4px}
        .form-group{margin-bottom:16px}
        label{display:block;font-size:11px;color:#666;font-family:Arial,sans-serif;margin-bottom:4px;font-weight:700;text-transform:uppercase;letter-spacing:.5px}
        input[type=text],input[type=password]{width:100%;border:1.5px solid #dde;border-radius:4px;padding:10px 12px;font-size:13px;font-family:Arial,sans-serif;color:#333;transition:border-color .15s}
        input:focus{outline:none;border-color:#0d1f3c}
        .error-msg{background:#fde8e8;border:1px solid #f5b8b8;color:#7b241c;padding:10px 14px;border-radius:4px;font-size:12px;font-family:Arial,sans-serif;margin-bottom:16px}
        .login-btn{width:100%;background:#e8c84a;color:#0d1f3c;border:none;padding:12px;font-size:14px;font-weight:700;border-radius:4px;cursor:pointer;font-family:Arial,sans-serif;transition:background .15s}
        .login-btn:hover{background:#f5d55a}
        .back-link{text-align:center;margin-top:18px}
        .back-link a{color:#aaa;font-size:12px;font-family:Arial,sans-serif;text-decoration:none}
        .back-link a:hover{color:#0d1f3c}
    </style>
</head>
<body>
    <div class="login-wrap">
        <div class="login-card">
            <div class="login-logo-wrap">
                <div class="login-logo-circle">
                    <img src="/images/c4comlogo.jpg" alt="CU4J Logo" />
                </div>
                <div class="login-title">CU4J Admin Portal</div>
                <div class="login-sub">501(c)(3) • Communities United for Justice</div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="error-msg">⚠ @ViewBag.Error</div>
            }

            <form method="post" asp-action="Login" asp-controller="Auth" asp-area="Admin" data-recaptcha>
                @Html.AntiForgeryToken()
                <input type="hidden" name="recaptchaToken" />
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="username" placeholder="admin" autocomplete="username" required />
                </div>
                <div class="form-group" style="margin-bottom:24px">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="••••••••" autocomplete="current-password" required />
                </div>
                <button type="submit" class="login-btn">Sign In →</button>
            </form>

            <div class="back-link">
                <a href="/">← Back to live site</a>
            </div>
        </div>
    </div>
@if (!string.IsNullOrWhiteSpace(_rcSiteKey))
{
<script src="https://www.google.com/recaptcha/api.js?render=@_rcSiteKey" async defer></script>
<script>
(function(){
    var RC_KEY = '@_rcSiteKey';
    var _readyToken = null;

    function getToken(cb) {
        if (_readyToken) { var t = _readyToken; _readyToken = null; cb(t); return; }
        if (typeof grecaptcha !== 'undefined') {
            grecaptcha.execute(RC_KEY, { action: 'submit' })
                .then(cb).catch(function() { cb(''); });
        } else {
            cb('');
        }
    }

    (function prefetch() {
        if (typeof grecaptcha !== 'undefined') {
            grecaptcha.ready(function() {
                grecaptcha.execute(RC_KEY, { action: 'submit' })
                    .then(function(t) { _readyToken = t; })
                    .catch(function() {});
            });
        } else {
            setTimeout(prefetch, 100);
        }
    })();

    var form = document.querySelector('form[data-recaptcha]');
    if (!form) return;
    form.addEventListener('submit', function(e) {
        var tokenInput = form.querySelector('input[name="recaptchaToken"]');
        if (!tokenInput) return;
        if (tokenInput.value) return;

        e.preventDefault();
        var done = false;
        function finish(token) {
            if (done) return; done = true;
            tokenInput.value = token;
            form.submit();
        }
        var fallback = setTimeout(function() { finish(''); }, 6000);
        getToken(function(t) { clearTimeout(fallback); finish(t); });
    });
})();
</script>
}
</body>
</html>
