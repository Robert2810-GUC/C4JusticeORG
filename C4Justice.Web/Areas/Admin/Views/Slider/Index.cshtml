@model IEnumerable<C4Justice.Web.Models.SliderImage>
@{
    ViewData["Title"] = "Hero Slider";
}

@section TopbarActions {
    <a href="/Admin/Slider/Create" class="btn-sm-admin btn-primary-admin"><i class="fas fa-plus me-1"></i>Add Image</a>
}

<div class="admin-card">
    @if (!Model.Any())
    {
        <p style="color:#8b949e;">No slider images yet. <a href="/Admin/Slider/Create" style="color:#fca5a5;">Add one</a>.</p>
    }
    else
    {
        <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div style="background:#0d1117;border:1px solid #30363d;border-radius:10px;overflow:hidden;">
                    <img src="@item.ImageUrl" style="width:100%;height:160px;object-fit:cover;" onerror="this.src='/images/community-1.png'" />
                    <div style="padding:14px;">
                        <div style="font-weight:600;color:#e6edf3;font-size:.875rem;margin-bottom:2px;">@(item.Title ?? "<em style='color:#8b949e;font-style:italic;'>No title</em>")</div>
                        @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                        {
                            <div style="font-size:.75rem;color:#8b949e;margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@item.Subtitle</div>
                        }
                        <div style="font-size:.72rem;color:#8b949e;margin-bottom:12px;">Sort order: @item.SortOrder</div>
                        <div class="d-flex gap-2 align-items-center flex-wrap">
                            <span class="@(item.IsActive ? "badge-active" : "badge-inactive")">@(item.IsActive ? "Active" : "Hidden")</span>
                            <!-- Edit -->
                            <a href="/Admin/Slider/Edit/@item.Id"
                               class="btn-sm-admin btn-primary-admin"
                               style="padding:4px 12px;font-size:.72rem;">
                                <i class="fas fa-pen me-1"></i>Edit
                            </a>
                            <!-- Toggle -->
                            <form method="post" asp-action="ToggleActive" asp-route-id="@item.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-sm-admin btn-ghost-admin" style="padding:4px 10px;font-size:.72rem;">
                                    @(item.IsActive ? "Hide" : "Show")
                                </button>
                            </form>
                            <!-- Delete -->
                            <form method="post" asp-action="Delete" asp-route-id="@item.Id" style="display:inline;"
                                  onsubmit="return confirm('Delete this slider image?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-sm-admin"
                                        style="padding:4px 10px;font-size:.72rem;background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);">
                                    <i class="fas fa-trash me-1"></i>Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
        </div>
    }
</div>
