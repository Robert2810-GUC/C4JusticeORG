@model C4Justice.Web.Models.SiteDocument
@{ ViewData["Title"] = "Edit Document"; }

<div style="max-width:680px">
    <div class="page-header">
        <div>
            <div class="page-title">Edit Document</div>
            <div class="page-sub">Update details for "@Model.FileName"</div>
        </div>
        <a href="/Admin/Documents" style="background:#f0f4ff;color:#0d1f3c;border:1.5px solid #dde;padding:8px 16px;border-radius:4px;font-size:12px;font-weight:700;font-family:Arial;text-decoration:none">← Back to Documents</a>
    </div>

    <div class="info-banner" style="margin-bottom:18px">
        <span style="font-size:18px;flex-shrink:0">📄</span>
        <div>
            <div style="font-weight:700;font-size:13px;color:#0d1f3c;font-family:Arial">@Model.FileName</div>
            <div style="font-size:11px;color:#888;font-family:Arial;margin-top:2px">@Model.FileSizeDisplay · .@Model.FileType.ToUpper() · Uploaded @Model.CreatedAt.ToString("MMM d, yyyy")</div>
        </div>
    </div>

    <div class="form-preview">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="form-group">
                <label>Document Title *</label>
                <input type="text" name="title" value="@Model.Title" required placeholder="Descriptive title shown to visitors" />
            </div>
            <div class="form-group">
                <label>Category</label>
                <select asp-for="Category" name="category">
                    <option value="General">General</option>
                    <option value="Policy">Policy</option>
                    <option value="Report">Report</option>
                    <option value="Guide">Guide</option>
                    <option value="Press Release">Press Release</option>
                    <option value="Legal">Legal</option>
                    <option value="Financial">Financial</option>
                    <option value="Annual Report">Annual Report</option>
                    <option value="Research">Research</option>
                </select>
            </div>
            <div class="form-group">
                <label>Description (optional)</label>
                <textarea name="description" rows="3" placeholder="Brief description of what this document contains...">@Model.Description</textarea>
            </div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:18px">
                <input type="checkbox" name="isPublished" value="true" id="isPublished" style="width:16px;height:16px;accent-color:#0d1f3c" @(Model.IsPublished ? "checked" : "") />
                <label for="isPublished" style="font-size:12px;color:#555;font-family:Arial;font-weight:600;cursor:pointer">Published — visible on the public site</label>
            </div>
            <div style="background:#f8faff;border:1.5px solid #dde;border-radius:4px;padding:12px 14px;margin-bottom:18px;font-size:11px;color:#888;font-family:Arial">
                To replace the file, delete this document and upload a new one.
                <a href="@Model.FileUrl" target="_blank" style="color:#0d1f3c;font-weight:700;margin-left:6px">View current file ↗</a>
            </div>
            <div style="display:flex;gap:8px">
                <a href="/Admin/Documents" class="submit-btn dark" style="flex:1;text-align:center;text-decoration:none;padding:9px;display:block">Cancel</a>
                <button type="submit" class="submit-btn" style="flex:2">Save Changes</button>
            </div>
        </form>
    </div>
</div>
