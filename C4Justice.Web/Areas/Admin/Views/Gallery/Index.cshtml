@using C4Justice.Web.Models
@{
    ViewData["Title"] = "Photo Gallery";
    var sliderImages = ViewBag.SliderImages as List<SliderImage> ?? new List<SliderImage>();
    var galleryPhotos = ViewBag.GalleryPhotos as List<GalleryPhoto> ?? new List<GalleryPhoto>();
    var collagePhotos = ViewBag.CollagePhotos as List<GalleryPhoto> ?? new List<GalleryPhoto>();
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div>
        <div class="page-title">Photo Gallery</div>
        <div class="page-sub">Manage hero slider, community gallery, and about us collage photos</div>
    </div>
</div>

<!-- MINI STATS -->
<div class="mini-stats">
    <div class="mini-stat">
        <div class="num">@galleryPhotos.Count</div>
        <div class="lbl">Gallery Photos</div>
    </div>
    <div class="mini-stat blue">
        <div class="num">@sliderImages.Count</div>
        <div class="lbl">Hero Slides</div>
    </div>
    <div class="mini-stat green">
        <div class="num">@collagePhotos.Count</div>
        <div class="lbl">Collage Photos</div>
    </div>
    <div class="mini-stat">
        <div class="num">@(sliderImages.Count + galleryPhotos.Count + collagePhotos.Count)</div>
        <div class="lbl">Total Photos</div>
    </div>
</div>

<!-- TABS -->
<div style="display:flex;gap:0;margin-bottom:20px;background:#fff;border-radius:6px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.06)">
    <button class="tab-btn active" id="tab-slider" onclick="switchTab('slider',this)" style="flex:1;padding:14px;text-align:center;font-size:13px;font-family:Arial;font-weight:600;cursor:pointer;border:none;background:#fffef8;color:#0d1f3c;border-bottom:3px solid #e8c84a">
        Hero Slider <span style="background:#e8c84a;color:#0d1f3c;font-size:10px;padding:2px 7px;border-radius:10px;margin-left:6px;font-weight:700">@sliderImages.Count</span>
    </button>
    <button class="tab-btn" id="tab-gallery" onclick="switchTab('gallery',this)" style="flex:1;padding:14px;text-align:center;font-size:13px;font-family:Arial;font-weight:600;cursor:pointer;border:none;background:#fff;color:#888;border-bottom:3px solid transparent">
        Community Gallery <span style="background:#f0f0f0;color:#888;font-size:10px;padding:2px 7px;border-radius:10px;margin-left:6px;font-weight:700">@galleryPhotos.Count</span>
    </button>
    <button class="tab-btn" id="tab-collage" onclick="switchTab('collage',this)" style="flex:1;padding:14px;text-align:center;font-size:13px;font-family:Arial;font-weight:600;cursor:pointer;border:none;background:#fff;color:#888;border-bottom:3px solid transparent">
        About Us Collage <span style="background:#f0f0f0;color:#888;font-size:10px;padding:2px 7px;border-radius:10px;margin-left:6px;font-weight:700">3</span>
    </button>
</div>

<!-- ═══ HERO SLIDER TAB ═══ -->
<div id="panel-slider" class="tab-panel">
    <div style="background:#fff3cd;border:1px solid #ffc107;border-radius:5px;padding:12px 16px;margin-bottom:18px;font-size:12px;color:#856404;font-family:Arial">
        ⠿ <strong>Drag to reorder</strong> — The order here determines which slide appears first on the homepage.
    </div>

    <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:24px" id="slider-list">
        @for (int i = 0; i < sliderImages.Count; i++)
        {
            var slide = sliderImages[i];
            <div data-id="@slide.Id">
                <!-- Slide row -->
                <div class="slide-row" style="background:#fff;border-radius:6px 6px 0 0;box-shadow:0 1px 4px rgba(0,0,0,.06);padding:14px 18px;display:flex;align-items:center;gap:14px;border-bottom:none" id="row-@slide.Id">
                    <div style="cursor:grab;color:#ccc;font-size:20px;flex-shrink:0">⠿</div>
                    <div style="width:80px;height:56px;border-radius:4px;background:linear-gradient(135deg,#1a3a6b,#0d1f3c);overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center">
                        @if (!string.IsNullOrEmpty(slide.ImageUrl))
                        {
                            <img src="@slide.ImageUrl" style="width:100%;height:100%;object-fit:cover" />
                        }
                        else
                        {
                            <span style="color:rgba(232,200,74,.5);font-size:10px;font-family:Arial">No image</span>
                        }
                    </div>
                    <div style="flex:1;min-width:0">
                        <div style="font-size:13px;font-weight:700;color:#0d1f3c;font-family:Arial;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                            @(string.IsNullOrEmpty(slide.Title) ? "(No title)" : slide.Title)
                        </div>
                        @if (!string.IsNullOrEmpty(slide.Subtitle))
                        {
                            <div style="font-size:11px;color:#999;font-family:Arial;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@slide.Subtitle</div>
                        }
                        <div style="margin-top:4px">
                            <span style="font-size:9px;background:@(slide.IsActive ? "#e8f5e9" : "#f5f5f5");color:@(slide.IsActive ? "#1b5e20" : "#999");padding:2px 7px;border-radius:10px;font-family:Arial;font-weight:700">
                                @(slide.IsActive ? "Active" : "Inactive") · Slide @(i+1)
                            </span>
                        </div>
                    </div>
                    <div style="display:flex;gap:6px;flex-shrink:0;align-items:center">
                        <button type="button" onclick="toggleEdit('slider-@slide.Id')" class="action-btn edit">Edit</button>
                        <form asp-action="ToggleSlider" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@slide.Id" />
                            <button type="submit" class="action-btn mark" style="white-space:nowrap">@(slide.IsActive ? "Deactivate" : "Activate")</button>
                        </form>
                        <form asp-action="DeleteSlider" method="post" style="display:inline" onsubmit="return confirm('Remove this slide?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@slide.Id" />
                            <button type="submit" class="action-btn del">Remove</button>
                        </form>
                    </div>
                </div>
                <!-- Inline edit panel -->
                <div id="slider-@slide.Id" class="edit-panel" style="display:none;background:#f8faff;border:1.5px solid #e8c84a;border-top:none;border-radius:0 0 6px 6px;padding:18px 20px">
                    <form method="post" asp-action="UpdateSlider" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@slide.Id" />
                        <input type="hidden" name="isActive" value="@slide.IsActive.ToString().ToLower()" />
                        <div style="display:grid;grid-template-columns:1fr 1fr 100px;gap:12px;margin-bottom:12px">
                            <div class="form-group" style="margin-bottom:0">
                                <label>Slide Title</label>
                                <input type="text" name="title" value="@slide.Title" placeholder="Headline text on slide" />
                            </div>
                            <div class="form-group" style="margin-bottom:0">
                                <label>Caption / Subtitle</label>
                                <input type="text" name="subtitle" value="@slide.Subtitle" placeholder="Subtitle (optional)" />
                            </div>
                            <div class="form-group" style="margin-bottom:0">
                                <label>Sort Order</label>
                                <input type="number" name="sortOrder" value="@slide.SortOrder" min="0" />
                            </div>
                        </div>
                        <div class="form-group" style="margin-bottom:12px">
                            <label>Replace Image (optional — leave blank to keep current)</label>
                            <div style="border:2px dashed #c0cce0;border-radius:4px;padding:10px 14px;background:#fff;display:flex;align-items:center;gap:12px;cursor:pointer" onclick="document.getElementById('img-@slide.Id').click()">
                                <img src="@slide.ImageUrl" style="width:60px;height:42px;object-fit:cover;border-radius:3px;background:#eee" onerror="this.style.background='#dde'" />
                                <span style="font-size:12px;color:#888;font-family:Arial">Click to select a new image (1920×800px recommended)</span>
                                <input type="file" id="img-@slide.Id" name="imageFile" accept=".jpg,.jpeg,.png,.webp" style="display:none" />
                            </div>
                        </div>
                        <div style="display:flex;gap:8px">
                            <button type="button" onclick="toggleEdit('slider-@slide.Id')" style="background:#f0f0f0;color:#555;border:1.5px solid #dde;border-radius:4px;padding:7px 18px;font-size:12px;font-family:Arial;font-weight:700;cursor:pointer">Cancel</button>
                            <button type="submit" class="submit-btn" style="padding:7px 24px;font-size:12px">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        @if (!sliderImages.Any())
        {
            <div style="text-align:center;padding:40px;color:#aaa;font-family:Arial;background:#fff;border-radius:6px">No slider images yet. Add one below.</div>
        }
    </div>

    <div class="section-title">Add New Slide</div>
    <div class="form-preview">
        <form method="post" asp-action="UploadSlider" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="upload-zone" onclick="document.getElementById('slider-file').click()">
                <div style="font-size:28px;margin-bottom:6px">🖼</div>
                <h4 style="font-size:13px;color:#0d1f3c;font-weight:700;margin-bottom:3px">Click to upload slider image</h4>
                <p>Recommended: 1920×800px, JPG or WebP</p>
                <input type="file" id="slider-file" name="imageFile" accept=".jpg,.jpeg,.png,.webp" style="display:none" required />
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 100px;gap:12px;margin-top:14px">
                <div class="form-group" style="margin-bottom:0">
                    <label>Slide Title</label>
                    <input type="text" name="title" placeholder="Headline text on slide" />
                </div>
                <div class="form-group" style="margin-bottom:0">
                    <label>Caption / Subtitle</label>
                    <input type="text" name="subtitle" placeholder="Subtitle (optional)" />
                </div>
                <div class="form-group" style="margin-bottom:0">
                    <label>Sort Order</label>
                    <input type="number" name="sortOrder" value="@sliderImages.Count" min="0" />
                </div>
            </div>
            <button type="submit" class="submit-btn" style="margin-top:14px">Add Slide</button>
        </form>
    </div>
</div>

<!-- ═══ COMMUNITY GALLERY TAB ═══ -->
<div id="panel-gallery" class="tab-panel" style="display:none">
    <div class="info-banner">
        <span style="font-size:16px;flex-shrink:0">🖼</span>
        <p>Community gallery photos appear in the public gallery section. Add labels to help identify events or people. Click "+ Slider" to feature a photo in the homepage hero.</p>
    </div>

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
        <div class="section-title" style="margin-bottom:0">Community Photos</div>
        <button class="submit-btn" style="padding:7px 16px;font-size:12px" onclick="document.getElementById('gallery-upload').click()">+ Upload Photo</button>
    </div>

    <form method="post" asp-action="UploadGallery" enctype="multipart/form-data" id="gallery-form">
        @Html.AntiForgeryToken()
        <input type="file" id="gallery-upload" name="imageFile" accept=".jpg,.jpeg,.png,.webp" style="display:none" onchange="this.form.submit()" />
    </form>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px;margin-bottom:20px" id="gallery-grid">
        @foreach (var photo in galleryPhotos)
        {
            <div style="background:#fff;border-radius:6px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.06);cursor:grab" data-id="@photo.Id">
                <div style="width:100%;height:130px;background:linear-gradient(135deg,#1a3a6b,#0d1f3c);overflow:hidden;position:relative">
                    <img src="@photo.ImageUrl" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none'" />
                </div>
                <!-- Display mode -->
                <div id="gallery-view-@photo.Id" style="padding:10px 10px 8px">
                    <div style="font-size:12px;color:#333;font-family:Arial;font-weight:600;min-height:18px;margin-bottom:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                        @(string.IsNullOrEmpty(photo.Label) ? "(No label)" : photo.Label)
                    </div>
                    <div style="display:flex;gap:4px">
                        <button type="button" onclick="toggleEdit('gallery-@photo.Id')" class="action-btn edit" style="flex:1;text-align:center;font-size:10px">Edit</button>
                        <form asp-action="AddToSlider" method="post" style="flex:1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="galleryId" value="@photo.Id" />
                            <button type="submit" style="width:100%;font-size:10px;padding:4px 0;border-radius:3px;border:none;cursor:pointer;font-family:Arial;font-weight:700;background:#e8f0ff;color:#0d1f3c">+ Slider</button>
                        </form>
                        <form asp-action="DeleteGalleryPhoto" method="post" style="flex:1" onsubmit="return confirm('Delete photo?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@photo.Id" />
                            <button type="submit" class="action-btn del" style="width:100%;font-size:10px;text-align:center">Del</button>
                        </form>
                    </div>
                </div>
                <!-- Edit mode -->
                <div id="gallery-@photo.Id" class="edit-panel" style="display:none;padding:10px;background:#f8faff;border-top:1.5px solid #e8c84a">
                    <form asp-action="UpdateGalleryPhoto" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@photo.Id" />
                        <div class="form-group" style="margin-bottom:8px">
                            <label style="font-size:10px">Label</label>
                            <input type="text" name="label" value="@photo.Label" placeholder="Photo label..." />
                        </div>
                        <div style="display:flex;gap:4px">
                            <button type="button" onclick="toggleEdit('gallery-@photo.Id')" style="flex:1;background:#f0f0f0;color:#555;border:1.5px solid #dde;border-radius:3px;padding:5px;font-size:10px;font-family:Arial;font-weight:700;cursor:pointer">Cancel</button>
                            <button type="submit" class="submit-btn" style="flex:2;padding:5px;font-size:10px">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        <!-- Upload placeholder tile -->
        <div style="background:#fff;border-radius:6px;border:2px dashed #c0cce0;display:flex;flex-direction:column;align-items:center;justify-content:center;height:210px;cursor:pointer" onclick="document.getElementById('gallery-upload').click()">
            <div style="font-size:28px;color:#0d1f3c;font-weight:300">+</div>
            <span style="font-size:11px;color:#999;font-family:Arial;margin-top:4px">Upload Photo</span>
        </div>
    </div>
</div>

<!-- ═══ ABOUT US COLLAGE TAB ═══ -->
<div id="panel-collage" class="tab-panel" style="display:none">
    <div class="info-banner">
        <span style="font-size:16px;flex-shrink:0">📸</span>
        <p>The About Us section displays a 3-photo portrait collage. Upload exactly 3 photos for the best visual layout. Recommended: portrait orientation (3:4 ratio).</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px">
        @for (int slot = 0; slot < 3; slot++)
        {
            var collagePhoto = collagePhotos.FirstOrDefault(p => p.SortOrder == slot);
            <div style="background:#fff;border-radius:6px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.06)">
                <div style="width:100%;height:220px;background:linear-gradient(135deg,#1a3a6b,#0d1f3c);overflow:hidden;display:flex;align-items:center;justify-content:center;position:relative">
                    @if (collagePhoto != null && !string.IsNullOrEmpty(collagePhoto.ImageUrl))
                    {
                        <img src="@collagePhoto.ImageUrl" style="width:100%;height:100%;object-fit:cover" />
                    }
                    else
                    {
                        <span style="color:rgba(232,200,74,.5);font-size:12px;font-family:Arial;text-align:center">Slot @(slot+1)<br/>No image</span>
                    }
                </div>
                <!-- Display -->
                <div id="collage-view-@slot" style="padding:10px 12px">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                        <span style="font-size:9px;background:#e8c84a;color:#0d1f3c;padding:2px 7px;border-radius:3px;font-family:Arial;font-weight:700">Collage @(slot+1)</span>
                        <span style="font-size:11px;color:#555;font-family:Arial">@(collagePhoto?.Label ?? "(No label)")</span>
                    </div>
                    <button type="button" onclick="toggleEdit('collage-@slot')" class="action-btn edit" style="width:100%;text-align:center;font-size:11px">Edit</button>
                    @if (collagePhoto != null)
                    {
                        <form asp-action="DeleteGalleryPhoto" method="post" onsubmit="return confirm('Remove this collage photo?')" style="margin-top:6px">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@collagePhoto.Id" />
                            <button type="submit" class="action-btn del" style="width:100%;text-align:center;font-size:11px">Remove</button>
                        </form>
                    }
                </div>
                <!-- Edit panel -->
                <div id="collage-@slot" class="edit-panel" style="display:none;padding:12px;background:#f8faff;border-top:1.5px solid #e8c84a">
                    <form method="post" asp-action="UploadCollage" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="slot" value="@slot" />
                        <div class="form-group" style="margin-bottom:10px">
                            <label>Label</label>
                            <input type="text" name="label" value="@collagePhoto?.Label" placeholder="Photo label..." />
                        </div>
                        <div class="form-group" style="margin-bottom:10px">
                            <label>Replace Image</label>
                            <div style="border:2px dashed #c0cce0;border-radius:4px;padding:8px 12px;background:#fff;font-size:11px;color:#888;font-family:Arial;cursor:pointer" onclick="document.getElementById('collage-file-@slot').click()">
                                📷 Click to select new image (portrait 3:4 recommended)
                                <input type="file" id="collage-file-@slot" name="imageFile" accept=".jpg,.jpeg,.png,.webp" style="display:none" @(collagePhoto == null ? "required" : "") />
                            </div>
                        </div>
                        <div style="display:flex;gap:6px">
                            <button type="button" onclick="toggleEdit('collage-@slot')" style="flex:1;background:#f0f0f0;color:#555;border:1.5px solid #dde;border-radius:3px;padding:6px;font-size:11px;font-family:Arial;font-weight:700;cursor:pointer">Cancel</button>
                            <button type="submit" class="submit-btn" style="flex:2;padding:6px;font-size:11px">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
<style>
.act-btn.share { background:#e8f0ff;color:#0d1f3c }
.act-btn.view  { background:#f5f5f5;color:#555 }
</style>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
function switchTab(name, btn) {
    document.querySelectorAll('.tab-panel').forEach(function(p){ p.style.display='none'; });
    document.querySelectorAll('.tab-btn').forEach(function(b){
        b.style.borderBottomColor='transparent';
        b.style.background='#fff';
        b.style.color='#888';
    });
    document.getElementById('panel-'+name).style.display='block';
    btn.style.borderBottomColor='#e8c84a';
    btn.style.background='#fffef8';
    btn.style.color='#0d1f3c';
}

function toggleEdit(id) {
    var panel = document.getElementById(id);
    if (!panel) return;
    var isOpen = panel.style.display !== 'none';
    document.querySelectorAll('.edit-panel').forEach(function(el) { el.style.display = 'none'; });
    if (!isOpen) panel.style.display = 'block';
}

function saveOrder(url, ids) {
    fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(ids)
    }).then(function(r) {
        if (r.ok) showReorderToast();
    });
}

function showReorderToast() {
    var t = document.getElementById('reorder-toast');
    if (!t) return;
    t.style.opacity = '1';
    setTimeout(function(){ t.style.opacity = '0'; }, 2000);
}

// Slider drag-to-reorder
var sliderList = document.getElementById('slider-list');
if (sliderList) {
    Sortable.create(sliderList, {
        animation: 150,
        handle: '.slide-row',
        ghostClass: 'drag-ghost',
        onEnd: function() {
            var ids = Array.from(sliderList.querySelectorAll('[data-id]'))
                          .map(function(el){ return parseInt(el.dataset.id); });
            saveOrder('/Admin/Gallery/ReorderSlider', ids);
        }
    });
}

// Gallery drag-to-reorder
var galleryGrid = document.getElementById('gallery-grid');
if (galleryGrid) {
    Sortable.create(galleryGrid, {
        animation: 150,
        ghostClass: 'drag-ghost',
        onEnd: function() {
            var ids = Array.from(galleryGrid.querySelectorAll('[data-id]'))
                          .map(function(el){ return parseInt(el.dataset.id); });
            saveOrder('/Admin/Gallery/ReorderGallery', ids);
        }
    });
}
</script>
<style>
.drag-ghost { opacity:.4; background:#e8f0ff !important; }
#slider-list .slide-row { cursor:grab; }
#slider-list .slide-row:active { cursor:grabbing; }
</style>
<div id="reorder-toast" style="position:fixed;bottom:24px;right:24px;background:#0d1f3c;color:#e8c84a;padding:10px 18px;border-radius:4px;font-size:12px;font-family:Arial;font-weight:700;opacity:0;transition:opacity .3s;z-index:9999;pointer-events:none">
    ✓ Order saved
</div>
}
