@model C4Justice.Web.Models.Article
@{
    ViewData["Title"] = "Edit Article";
    bool hasImage = !string.IsNullOrWhiteSpace(Model.FeaturedImageUrl);
}

@section Styles {
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<style>
.ql-toolbar.ql-snow{background:#f8faff;border-color:#dde;border-radius:4px 4px 0 0;font-family:Arial,sans-serif}
.ql-container.ql-snow{background:#fff;border-color:#dde;border-radius:0 0 4px 4px}
.ql-editor{font-family:Georgia,serif;font-size:14px;min-height:280px;color:#333;line-height:1.7}
.ql-editor.ql-blank::before{color:#bbb;font-style:normal}
</style>
}

<div class="page-header">
    <div>
        <div class="page-title">Edit Article</div>
        <div class="page-sub">/Opinion/@Model.Slug</div>
    </div>
    <a href="/Admin/Articles" style="background:#f0f4ff;color:#0d1f3c;border:1.5px solid #dde;padding:8px 16px;border-radius:4px;font-size:12px;font-weight:700;font-family:Arial;text-decoration:none">← Back</a>
</div>

<div style="display:grid;grid-template-columns:1fr 300px;gap:20px;align-items:start">
    <div class="form-preview">
        <form id="articleForm" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="Slug" type="hidden" />
            <input type="hidden" id="removeImage" name="removeImage" value="false" />
            <div class="form-group">
                <label>Title *</label>
                <input asp-for="Title" placeholder="Article title" required />
            </div>
            <div class="form-group">
                <label>Excerpt (short summary)</label>
                <textarea asp-for="Excerpt" placeholder="One or two sentence summary shown in listings..."></textarea>
            </div>
            <div class="form-group">
                <label>Content *</label>
                <div id="quillEditor"></div>
                <textarea id="richContent" name="Content" style="display:none" required></textarea>
            </div>
            <div style="margin-top:16px;display:flex;gap:8px">
                <a href="/Admin/Articles" class="submit-btn dark" style="flex:1;text-align:center;text-decoration:none;padding:9px;display:block">Cancel</a>
                <button type="submit" class="submit-btn" style="flex:2">Update Article</button>
            </div>
        </form>
    </div>

    <div style="position:sticky;top:76px">
        <div class="section-title">Publish Settings</div>
        <div class="form-preview">
            <div class="form-group">
                <label>Category</label>
                <select asp-for="Category" form="articleForm">
                    <option value="General">General</option>
                    <option value="Political">Political</option>
                    <option value="Racial">Racial</option>
                    <option value="Economic">Economic</option>
                    <option value="Healthcare">Healthcare</option>
                    <option value="Environmental">Environmental</option>
                </select>
            </div>
            <div class="form-group">
                <label>Featured Image</label>
                <div id="imgDropZone" style="border:2px dashed #c0cce0;border-radius:4px;padding:@(hasImage ? "0" : "16px");text-align:center;cursor:pointer;background:#f8faff;transition:border-color .2s;overflow:hidden" onclick="document.getElementById('FeaturedImageInput').click()">
                    @if (hasImage)
                    {
                        <img id="imgPreview" src="@Model.FeaturedImageUrl" style="display:block;width:100%;max-height:140px;border-radius:4px;object-fit:cover" />
                    }
                    else
                    {
                        <div id="imgPlaceholder" style="font-size:11px;color:#aaa;font-family:Arial">
                            <div style="font-size:24px;margin-bottom:6px">📷</div>
                            Click to upload image
                        </div>
                        <img id="imgPreview" src="" style="display:none;max-width:100%;max-height:140px;border-radius:4px;object-fit:cover" />
                    }
                </div>
                <input type="file" id="FeaturedImageInput" name="FeaturedImage" accept="image/*" style="display:none" form="articleForm" />
                @if (hasImage)
                {
                    <button type="button" onclick="removeImg()" style="margin-top:6px;width:100%;background:#fff0f0;color:#c0392b;border:1.5px solid #f5c6cb;border-radius:4px;padding:6px;font-size:11px;font-family:Arial;font-weight:700;cursor:pointer">Remove Image</button>
                }
            </div>
            <div style="margin-bottom:8px">
                <div style="font-size:11px;color:#888;font-family:Arial">Slug: <code style="color:#0d1f3c">/Opinion/@Model.Slug</code></div>
            </div>
            <div style="font-size:11px;color:#aaa;font-family:Arial;margin-bottom:8px">
                Created: @Model.CreatedAt.ToString("MMM d, yyyy")
                @if (Model.PublishedAt.HasValue) { <text>· Published: @Model.PublishedAt.Value.ToString("MMM d, yyyy")</text> }
            </div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:0">
                <input asp-for="IsPublished" type="checkbox" style="width:16px;height:16px;accent-color:#0d1f3c" form="articleForm" />
                <label style="font-size:12px;color:#555;font-family:Arial;font-weight:600;cursor:pointer">Published</label>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
const quill = new Quill('#quillEditor', {
    theme: 'snow',
    placeholder: 'Write article content here...',
    modules: { toolbar: [
        [{ header: [1, 2, 3, false] }],
        ['bold', 'italic', 'underline'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['blockquote', 'link'], ['clean']
    ]}
});

quill.root.innerHTML = @Html.Raw(Json.Serialize(Model.Content ?? ""));

document.getElementById('articleForm').addEventListener('submit', function(e) {
    var content = quill.root.innerHTML;
    if (!content || content === '<p><br></p>') { e.preventDefault(); return; }
    document.getElementById('richContent').value = content;
});

document.getElementById('FeaturedImageInput').addEventListener('change', function() {
    if (this.files.length) {
        var reader = new FileReader();
        reader.onload = function(e) {
            var preview = document.getElementById('imgPreview');
            var placeholder = document.getElementById('imgPlaceholder');
            preview.src = e.target.result;
            preview.style.display = 'block';
            if (placeholder) placeholder.style.display = 'none';
            document.getElementById('imgDropZone').style.padding = '0';
            document.getElementById('removeImage').value = 'false';
        };
        reader.readAsDataURL(this.files[0]);
    }
});

function removeImg() {
    document.getElementById('removeImage').value = 'true';
    document.getElementById('imgPreview').style.display = 'none';
    var placeholder = document.getElementById('imgPlaceholder');
    if (placeholder) { placeholder.style.display = 'block'; }
    else {
        var dz = document.getElementById('imgDropZone');
        dz.innerHTML = '<div id="imgPlaceholder" style="font-size:11px;color:#aaa;font-family:Arial"><div style="font-size:24px;margin-bottom:6px">📷</div>Click to upload image</div><img id="imgPreview" src="" style="display:none;max-width:100%;max-height:140px;border-radius:4px;object-fit:cover" />';
    }
    document.getElementById('imgDropZone').style.padding = '16px';
}
</script>
}
