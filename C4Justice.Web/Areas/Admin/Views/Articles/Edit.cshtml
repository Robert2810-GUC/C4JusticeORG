@model C4Justice.Web.Models.Article
@{
    ViewData["Title"] = "Edit Article";
    bool hasImage = !string.IsNullOrWhiteSpace(Model.FeaturedImageUrl);
}

<div class="row g-4">
<div class="col-lg-8">
<div class="admin-card">
    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="Slug" type="hidden" />
                <input type="file" id="FeaturedImage" name="newImage" accept="image/*" style="display:none;" />
                <div class="mb-3">
            <label class="admin-form-label">Title *</label>
            <input asp-for="Title" class="admin-form-control" required />
        </div>
        <div class="mb-3">
            <label class="admin-form-label">Excerpt</label>
            <textarea asp-for="Excerpt" class="admin-form-control" rows="2"></textarea>
        </div>
        <div class="mb-3">
            <label class="admin-form-label">Content *</label>
            <textarea asp-for="Content" id="richContent" class="admin-form-control" rows="12" required></textarea>
        </div>
        <button type="submit" class="btn-sm-admin btn-primary-admin" style="padding:10px 28px;">Update Article</button>
        <a href="/Admin/Articles" class="btn-sm-admin btn-ghost-admin" style="padding:10px 20px;">Cancel</a>
    </form>
</div>
</div>

<div class="col-lg-4">
<div class="admin-card">
    <h6 style="color:#e6edf3;font-weight:700;margin-bottom:16px;">Settings</h6>
    <div class="mb-3">
        <label class="admin-form-label">Category</label>
        <select asp-for="Category" class="admin-form-control">
            <option value="General">General</option>
            <option value="Political">Political</option>
            <option value="Racial">Racial</option>
            <option value="Economic">Economic</option>
            <option value="Healthcare">Healthcare</option>
            <option value="Environmental">Environmental</option>
        </select>
    </div>

    <!-- Featured Image Upload -->
    <div class="mb-3">
        <label class="admin-form-label">Featured Image</label>

        <!-- Drop Zone -->
        <div id="imgDropZone" style="border:2px dashed rgba(255,255,255,0.15);border-radius:6px;padding:@(hasImage ? "0" : "16px");text-align:center;cursor:pointer;transition:border-color 0.2s;background:rgba(255,255,255,0.03);overflow:hidden;">
            @if (hasImage)
            {
                <img id="imgPreview" src="@Model.FeaturedImageUrl" alt="Featured Image"
                     style="width:100%;max-height:180px;object-fit:cover;display:block;border-radius:4px;" />
            }
            else
            {
                <img id="imgPreview" src="" alt="Preview" style="display:none;width:100%;max-height:180px;object-fit:cover;border-radius:4px;" />
                <div id="imgPlaceholder">
                    <i class="fas fa-cloud-upload-alt" style="font-size:1.8rem;color:#8b949e;margin-bottom:8px;display:block;"></i>
                    <span style="font-size:12px;color:#8b949e;">Click or drag &amp; drop an image</span><br>
                    <span style="font-size:11px;color:#6e7681;">JPG, PNG, GIF, WebP — max 5 MB</span>
                </div>
            }
        </div>
        @if (!hasImage)
        {
            <div id="imgPlaceholderWrap" style="display:none;"></div>
        }

        <input type="file" id="FeaturedImage" name="FeaturedImage" accept="image/*" style="display:none;" />

        <!-- Action buttons below the drop zone -->
        <div style="margin-top:8px;display:flex;gap:8px;align-items:center;">
            <button type="button" id="btnChangeImg" class="btn-sm-admin btn-ghost-admin" style="font-size:11px;padding:5px 12px;">
                @(hasImage ? "Change Image" : "Upload Image")
            </button>
            @if (hasImage)
            {
                <button type="button" id="btnRemoveImg" class="btn-sm-admin"
                        style="font-size:11px;padding:5px 12px;background:rgba(220,38,38,0.15);color:#fca5a5;border:1px solid rgba(220,38,38,0.3);border-radius:4px;">
                    Remove Image
                </button>
            }
            else
            {
                <button type="button" id="btnRemoveImg"
                        style="font-size:11px;padding:5px 12px;background:rgba(220,38,38,0.15);color:#fca5a5;border:1px solid rgba(220,38,38,0.3);border-radius:4px;display:none;">
                    Remove Image
                </button>
            }
        </div>

        <input type="hidden" id="removeImage" name="removeImage" value="false" />
    </div>

    <div class="d-flex align-items-center gap-2 mt-3">
        <input asp-for="IsPublished" type="checkbox" style="width:16px;height:16px;" />
        <label class="admin-form-label mb-0">Published</label>
    </div>
    <div class="mt-3" style="font-size:.75rem;color:#8b949e;">
        Slug: <code style="color:#fca5a5;">/Opinion/@Model.Slug</code>
    </div>
</div>
</div>
</div>

@section Scripts {
<script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<script>
tinymce.init({
    selector: '#richContent',
    plugins: 'lists link image code',
    toolbar: 'undo redo | bold italic | bullist numlist | link | code',
    skin: 'oxide-dark', content_css: 'dark',
    height: 400, menubar: false
});

// ── Image Upload UI ──────────────────────────────────────
const dropZone       = document.getElementById('imgDropZone');
const fileInput      = document.getElementById('FeaturedImage');
const imgPreview     = document.getElementById('imgPreview');
const btnChange      = document.getElementById('btnChangeImg');
const btnRemove      = document.getElementById('btnRemoveImg');
const hiddenUrl      = document.getElementById('hiddenImageUrl');
const hasImageInit   = @(hasImage ? "true" : "false");

function getPlaceholder() { return document.getElementById('imgPlaceholder'); }

function showPreview(src) {
    imgPreview.src = src;
    imgPreview.style.display = 'block';
    const ph = getPlaceholder();
    if (ph) ph.style.display = 'none';
    dropZone.style.padding = '0';
    dropZone.style.borderColor = 'rgba(200,169,81,0.5)';
    btnChange.textContent = 'Change Image';
    btnRemove.style.display = 'inline-block';
}

function clearPreview() {
    imgPreview.src = '';
    imgPreview.style.display = 'none';
    const ph = getPlaceholder();
    if (ph) ph.style.display = 'block';
    dropZone.style.padding = '16px';
    dropZone.style.borderColor = 'rgba(255,255,255,0.15)';
    btnChange.textContent = 'Upload Image';
    btnRemove.style.display = 'none';
    fileInput.value = '';
    hiddenUrl.value = '';
}

// Drag & drop
dropZone.addEventListener('click', () => fileInput.click());
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.style.borderColor = 'rgba(200,169,81,0.7)'; });
dropZone.addEventListener('dragleave', () => dropZone.style.borderColor = imgPreview.src ? 'rgba(200,169,81,0.5)' : 'rgba(255,255,255,0.15)');
dropZone.addEventListener('drop', e => {
    e.preventDefault();
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('image/')) {
        const dt = new DataTransfer();
        dt.items.add(file);
        fileInput.files = dt.files;
        readFile(file);
    }
});

fileInput.addEventListener('change', () => {
    if (fileInput.files.length) readFile(fileInput.files[0]);
});

function readFile(file) {
    const reader = new FileReader();
    reader.onload = e => showPreview(e.target.result);
    reader.readAsDataURL(file);
}

btnChange.addEventListener('click', e => { e.stopPropagation(); fileInput.click(); });

btnRemove.addEventListener('click', e => {
    e.stopPropagation();
    clearPreview();
});
</script>
}
