@{
    ViewData["Title"] = "Confirm Data Replacement";
    var existingCount = (int)(ViewBag.ExistingCount ?? 0);
    var newCount      = (int)(ViewBag.NewCount ?? 0);
    var asOfDate      = (DateTime)(ViewBag.AsOfDate ?? DateTime.MinValue);
}

<div class="page-header">
    <div>
        <div class="page-title">Duplicate Month Detected</div>
        <div class="page-sub">Data already exists for this month — confirm to replace it</div>
    </div>
</div>

<div style="max-width:600px">

    <div class="warning-banner" style="display:flex;gap:10px;align-items:flex-start">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#856404" stroke-width="2" style="flex-shrink:0;margin-top:1px"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <div>
            <strong>Records already exist for @asOfDate.ToString("MMMM yyyy")</strong><br>
            Uploading this file will <strong>delete @existingCount.ToString("N0") existing records</strong> and
            replace them with <strong>@newCount.ToString("N0") new records</strong> from the uploaded file.
            <br><br>
            This action cannot be undone. Are you sure you want to continue?
        </div>
    </div>

    <div class="form-preview" style="margin-top:16px">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px">
            <div style="background:#fff3cd;border-radius:5px;padding:14px;text-align:center">
                <div style="font-size:24px;font-weight:700;color:#856404">@existingCount.ToString("N0")</div>
                <div style="font-size:11px;color:#856404;font-family:Arial,sans-serif;margin-top:3px">Records to Delete</div>
            </div>
            <div style="background:#d4edda;border-radius:5px;padding:14px;text-align:center">
                <div style="font-size:24px;font-weight:700;color:#155724">@newCount.ToString("N0")</div>
                <div style="font-size:11px;color:#155724;font-family:Arial,sans-serif;margin-top:3px">New Records to Import</div>
            </div>
        </div>

        <div style="display:flex;gap:10px">
            <form asp-action="ConfirmReplace" method="post" style="flex:1" id="confirmForm">
                @Html.AntiForgeryToken()
                <button type="submit" class="submit-btn" id="confirmBtn" style="background:#c0392b;color:#fff;width:100%">
                    ✓ Yes, Replace @asOfDate.ToString("MMMM yyyy") Data
                </button>
            </form>
            <form asp-action="CancelReplace" method="post" style="flex:1">
                @Html.AntiForgeryToken()
                <button type="submit" class="submit-btn dark" style="width:100%">✗ Cancel — Keep Existing Data</button>
            </form>
        </div>
    </div>

</div>

@section Scripts {
<script>
    document.getElementById('confirmForm').addEventListener('submit', function() {
        var btn = document.getElementById('confirmBtn');
        btn.textContent = '⏳ Replacing… please wait';
        btn.disabled = true;
    });
</script>
}
