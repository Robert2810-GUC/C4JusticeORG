@model IEnumerable<C4Justice.Web.Models.AdminUser>
@{
    ViewData["Title"] = "Admin Users";
    var currentId = Context.Session.GetInt32("AdminUserId");
}

@section TopbarActions {
    <a href="/Admin/Users/Create" class="view-site-btn" style="background:#e8c84a;color:#0d1f3c">+ Add User</a>
}

<div class="page-header">
    <div>
        <div class="page-title">Admin Users</div>
        <div class="page-sub">Manage who has access to this admin panel</div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:#e8f5e9;border:1px solid #a5d6a7;border-radius:4px;padding:12px 16px;margin-bottom:16px;color:#2e7d32;font-size:13px;font-family:Arial">
        ✓ @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:#ffeaea;border:1px solid #f5c6cb;border-radius:4px;padding:12px 16px;margin-bottom:16px;color:#c0392b;font-size:13px;font-family:Arial">
        ⚠ @TempData["Error"]
    </div>
}

<div class="table-card">
    <div style="background:#0d1f3c;display:grid;grid-template-columns:2fr 2fr 1fr 1fr 1fr 120px;padding:10px 16px;gap:12px">
        <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Username</div>
        <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Email</div>
        <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Role</div>
        <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Status</div>
        <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Last Login</div>
        <div style="color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;font-family:Arial;font-weight:600">Actions</div>
    </div>

    @foreach (var user in Model)
    {
        var isMe = user.Id == currentId;
        <div style="display:grid;grid-template-columns:2fr 2fr 1fr 1fr 1fr 120px;padding:14px 16px;gap:12px;align-items:center;border-bottom:.5px solid #f0f0f0;@(isMe ? "background:#fffdf0;" : "")">
            <div style="font-size:13px;font-weight:700;color:#0d1f3c;font-family:Arial">
                @user.Username
                @if (isMe)
                {
                    <span style="font-size:10px;color:#e8c84a;background:#0d1f3c;padding:1px 6px;border-radius:2px;margin-left:4px">
                        You
                    </span>
                }
            </div>
            <div style="font-size:12px;color:#555;font-family:Arial">@user.Email</div>
            <div>
                @if (user.Role == "super")
                {
                    <span style="font-size:10px;font-weight:700;background:#0d1f3c;color:#e8c84a;padding:3px 8px;border-radius:3px;font-family:Arial">SUPER</span>
                }
                else
                {
                    <span style="font-size:10px;font-weight:700;background:#e8f0ff;color:#0d1f3c;padding:3px 8px;border-radius:3px;font-family:Arial">ADMIN</span>
                }
            </div>
            <div>
                @if (user.IsActive)
                {
                    <span class="badge upcoming">Active</span>
                }
                else
                {
                    <span class="badge expired">Inactive</span>
                }
            </div>
            <div style="font-size:11px;color:#888;font-family:Arial">
                @(user.LastLoginAt.HasValue ? user.LastLoginAt.Value.ToString("MMM d, yyyy") : "Never")
            </div>
            <div style="display:flex;gap:5px;flex-wrap:wrap">
                @if (!isMe)
                {
                    <form method="post" action="/Admin/Users/ToggleActive/@user.Id" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="act-btn" style="background:#f0f4ff;color:#0d1f3c;font-size:10px;padding:4px 8px;border-radius:3px;border:none;cursor:pointer;font-family:Arial;font-weight:600">
                            @(user.IsActive ? "Disable" : "Enable")
                        </button>
                    </form>
                    <form method="post" action="/Admin/Users/Delete/@user.Id" style="display:inline" onsubmit="return confirm('Delete user @user.Username? This cannot be undone.')">
                        @Html.AntiForgeryToken()
                        <button type="submit" style="background:#ffeaea;color:#c0392b;font-size:10px;padding:4px 8px;border-radius:3px;border:none;cursor:pointer;font-family:Arial;font-weight:600">Delete</button>
                    </form>
                }
                else
                {
                    <span style="font-size:11px;color:#ccc;font-family:Arial;font-style:italic">—</span>
                }
            </div>
        </div>
    }
</div>
