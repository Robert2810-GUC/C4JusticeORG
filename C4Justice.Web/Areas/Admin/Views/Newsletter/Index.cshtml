@using C4Justice.Web.Models
@model List<NewsletterSubscription>
@{ ViewData["Title"] = "Subscribers"; }

@section TopbarActions {
    <a href="/Admin/Newsletter/Export" class="view-site-btn" style="background:#0d1f3c;color:#fff">⬇ Export to Excel</a>
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div>
        <div class="page-title">Newsletter Subscribers</div>
        <div class="page-sub">Manage your mailing list and export subscriber data</div>
    </div>
</div>

<!-- MINI STATS -->
<div class="mini-stats">
    <div class="mini-stat">
        <div class="num">@Model.Count(s => s.IsActive)</div>
        <div class="lbl">Total Subscribers</div>
        <div class="trend">↑ Active</div>
    </div>
    <div class="mini-stat blue">
        <div class="num">@Model.Count(s => s.SubscribedAt >= DateTime.UtcNow.AddDays(-30))</div>
        <div class="lbl">New This Month</div>
    </div>
    <div class="mini-stat green">
        <div class="num">@Model.Count(s => !string.IsNullOrEmpty(s.Phone))</div>
        <div class="lbl">With Mobile #</div>
    </div>
    <div class="mini-stat purple">
        <div class="num">@Model.Where(s => !string.IsNullOrEmpty(s.ZipCode)).Select(s => s.ZipCode).Distinct().Count()</div>
        <div class="lbl">Zip Codes</div>
    </div>
</div>

<!-- FILTER BAR -->
<div class="filter-bar" id="filter-bar">
    <button class="filter-btn active" onclick="filterSubs('all',this)">All</button>
    <button class="filter-btn" onclick="filterSubs('mobile',this)">With Mobile</button>
    <button class="filter-btn" onclick="filterSubs('month',this)">This Month</button>
    <button class="filter-btn" onclick="filterSubs('active',this)">Active Only</button>
    <div class="search-wrap" style="margin-left:auto;position:relative">
        <span class="sicon" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:13px;color:#aaa">🔍</span>
        <input type="text" id="search-input" placeholder="Search subscribers..." onkeyup="searchSubs(this.value)" style="border:1.5px solid #dde;border-radius:4px;padding:7px 12px 7px 32px;font-size:12px;font-family:Arial,sans-serif;color:#333;width:240px" />
    </div>
</div>

@if (!Model.Any())
{
    <div style="text-align:center;padding:60px 20px;color:#aaa;font-family:Arial">
        <div style="font-size:48px;margin-bottom:12px">📋</div>
        <p>No newsletter subscribers yet.</p>
    </div>
}
else
{
    <div class="table-card">
        <div class="table-wrap">
            <table id="subs-table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Email Address</th>
                        <th>Mobile Phone</th>
                        <th>Zip Code</th>
                        <th>Date Joined</th>
                        <th>Topic Interest</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var n in Model.OrderByDescending(s => s.SubscribedAt))
                {
                    <tr class="sub-row"
                        data-has-mobile="@(!string.IsNullOrEmpty(n.Phone) ? "1" : "0")"
                        data-this-month="@(n.SubscribedAt >= DateTime.UtcNow.AddDays(-30) ? "1" : "0")"
                        data-active="@(n.IsActive ? "1" : "0")"
                        data-search="@($"{n.FullName} {n.Email} {n.ZipCode}".ToLower())">
                        <td><strong style="color:#0d1f3c">@n.FullName</strong></td>
                        <td><a href="mailto:@n.Email" style="color:#0d1f3c;text-decoration:none;font-size:12px">@n.Email</a></td>
                        <td style="font-size:12px;color:#555">@(string.IsNullOrEmpty(n.Phone) ? "—" : n.Phone)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(n.ZipCode))
                            {
                                <span style="background:#e8f0ff;color:#0d1f3c;padding:2px 7px;border-radius:3px;font-size:11px;font-family:Arial;font-weight:600">@n.ZipCode</span>
                            }
                            else { <span style="color:#aaa">—</span> }
                        </td>
                        <td style="font-size:11px;color:#aaa">@n.SubscribedAt.ToString("MMM d, yyyy")</td>
                        <td style="font-size:12px">@(n.TopicInterest ?? "All Areas")</td>
                        <td>
                            @if (n.IsActive) { <span class="badge active">Active</span> }
                            else { <span class="badge expired">Unsub</span> }
                        </td>
                        <td>
                            <form asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Remove this subscriber?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="action-btn del">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script>
function filterSubs(type, btn) {
    document.querySelectorAll('.filter-btn').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
    document.querySelectorAll('.sub-row').forEach(function(row) {
        var show = true;
        if (type === 'mobile') show = row.dataset.hasMobile === '1';
        else if (type === 'month') show = row.dataset.thisMonth === '1';
        else if (type === 'active') show = row.dataset.active === '1';
        row.style.display = show ? '' : 'none';
    });
}
function searchSubs(q) {
    var lower = q.toLowerCase();
    document.querySelectorAll('.sub-row').forEach(function(row) {
        row.style.display = row.dataset.search.indexOf(lower) !== -1 ? '' : 'none';
    });
}
</script>
}
