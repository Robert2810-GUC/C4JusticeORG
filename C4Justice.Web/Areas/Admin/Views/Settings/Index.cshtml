@model List<C4Justice.Web.Models.SiteSetting>
@{
    ViewData["Title"] = "Site Settings";
    var grouped = Model.GroupBy(s => s.Group ?? "General").OrderBy(g => g.Key);
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div>
        <div class="page-title">Site Settings</div>
        <div class="page-sub">Manage all public-facing content settings — changes take effect immediately</div>
    </div>
</div>

<form asp-action="Save" method="post">
    @Html.AntiForgeryToken()

    @foreach (var group in grouped)
    {
        @if (group.Key == "Zeffy") { continue; }
        <div style="background:#fff;border-radius:6px;box-shadow:0 1px 4px rgba(0,0,0,.06);overflow:hidden;margin-bottom:20px">
            <div style="background:#0d1f3c;padding:14px 18px">
                <h3 style="color:#e8c84a;font-size:14px">@group.Key Section</h3>
            </div>
            <div style="padding:20px">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
                    @foreach (var s in group)
                    {
                        var isLong = (s.Value?.Length ?? 0) > 80 || s.Key.Contains("desc") || s.Key.Contains("lead") || s.Key.Contains("text");
                        <div class="form-group" style="@(isLong ? "grid-column:1/-1" : "")">
                            <label>@(s.Label ?? s.Key)</label>
                            @if (isLong)
                            {
                                <textarea name="values[@s.Key]" rows="3">@s.Value</textarea>
                            }
                            else
                            {
                                <input type="text" name="values[@s.Key]" value="@s.Value" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div style="display:flex;gap:8px;max-width:400px">
        <a href="/Admin/Dashboard" class="submit-btn dark" style="flex:1;text-align:center;text-decoration:none;padding:9px;display:block">Cancel</a>
        <button type="submit" class="submit-btn" style="flex:2">💾 Save All Settings</button>
    </div>
</form>
