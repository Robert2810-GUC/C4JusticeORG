@model List<C4Justice.Web.Models.SiteSetting>
@{
    ViewData["Title"] = "Site Settings";
    var grouped = Model.GroupBy(s => s.Group ?? "General").OrderBy(g => g.Key);
}

@section TopbarActions {
    <span style="color:var(--bs-secondary-color);font-size:.85rem;">
        <i class="fas fa-info-circle me-1"></i> Changes take effect immediately on the public site.
    </span>
}

<div class="d-flex align-items-center mb-4 gap-3">
    <div>
        <h4 class="mb-0 fw-bold">Site Settings</h4>
        <p class="text-muted small mb-0">Manage all public-facing content from one place</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 rounded-3 mb-4" style="background:rgba(34,197,94,0.1);color:#4ade80;border:1px solid rgba(34,197,94,0.2) !important;">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
    </div>
}

<form asp-action="Save" method="post">
    @Html.AntiForgeryToken()

    @foreach (var group in grouped)
    {
        <div class="card border-0 rounded-4 mb-4" style="background:#161b22;border:1px solid #30363d !important;">
            <div class="card-header border-0 rounded-top-4 py-3 px-4" style="background:rgba(255,255,255,0.03);">
                <h6 class="mb-0 fw-bold" style="color:#e6edf3;">
                    @{
                        var icon = group.Key switch {
                            "Hero"  => "fa-star",
                            "Stats" => "fa-chart-bar",
                            "About" => "fa-info-circle",
                            "Quote" => "fa-quote-left",
                            _       => "fa-cog"
                        };
                    }
                    <i class="fas @icon me-2" style="color:#b91c1c;"></i>@group.Key Section
                </h6>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    @foreach (var s in group)
                    {
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold" style="color:#8b949e;">@(s.Label ?? s.Key)</label>
                            @{
                                var isLong = (s.Value?.Length ?? 0) > 80 || (s.Key.Contains("desc") || s.Key.Contains("lead") || s.Key.Contains("text"));
                            }
                            @if (isLong)
                            {
                                <textarea name="values[@s.Key]" class="form-control" rows="3"
                                    style="background:#0d1117;border-color:#30363d;color:#e6edf3;border-radius:10px;resize:vertical;">@s.Value</textarea>
                            }
                            else
                            {
                                <input type="text" name="values[@s.Key]" value="@s.Value" class="form-control"
                                    style="background:#0d1117;border-color:#30363d;color:#e6edf3;border-radius:10px;" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="d-flex gap-3">
        <button type="submit" class="btn px-4 py-2 fw-semibold" style="background:#b91c1c;color:white;border-radius:10px;">
            <i class="fas fa-save me-2"></i>Save All Settings
        </button>
        <a href="/Admin/Dashboard" class="btn px-4 py-2 fw-semibold" style="background:#21262d;color:#e6edf3;border-radius:10px;border:1px solid #30363d;">
            Cancel
        </a>
    </div>
</form>
