<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — CU4J Admin</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    @RenderSection("Styles", required: false)
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:'Georgia',serif;background:#f0f2f7;color:#1a1a2e;display:flex;min-height:100vh}

        /* SIDEBAR */
        .sidebar{width:240px;background:#0d1f3c;display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;z-index:100;overflow-y:auto}
        .sidebar-logo{padding:20px 18px;border-bottom:1px solid rgba(232,200,74,.2);display:flex;align-items:center;gap:10px;flex-shrink:0}
        .logo-box{width:42px;height:42px;border-radius:50%;border:2px solid #e8c84a;overflow:hidden;flex-shrink:0;background:#0d1f3c}
        .logo-box img{width:100%;height:100%;object-fit:cover;display:block}
        .logo-text span{display:block;color:#fff;font-size:11px;font-weight:700;font-family:Arial,sans-serif}
        .logo-text small{color:#e8c84a;font-size:9px;letter-spacing:.8px;font-family:Arial,sans-serif}
        .sidebar-label{color:rgba(232,200,74,.5);font-size:9px;letter-spacing:2px;text-transform:uppercase;padding:16px 18px 6px;font-family:Arial,sans-serif;flex-shrink:0}
        .nav-item{display:flex;align-items:center;gap:10px;padding:10px 18px;cursor:pointer;border-left:3px solid transparent;transition:all .2s;font-family:Arial,sans-serif;font-size:13px;color:#a0b4cc;text-decoration:none}
        .nav-item:hover{background:rgba(232,200,74,.08);color:#fff;border-left-color:rgba(232,200,74,.3)}
        .nav-item.active{background:rgba(232,200,74,.12);color:#e8c84a;border-left-color:#e8c84a}
        .nav-icon{width:15px;height:15px;flex-shrink:0;opacity:.7}
        .nav-item.active .nav-icon{opacity:1}
        .nav-badge{background:#e8c84a;color:#0d1f3c;font-size:9px;font-weight:700;border-radius:10px;padding:1px 6px;margin-left:auto;font-family:Arial,sans-serif}
        .sidebar-footer{margin-top:auto;padding:16px 18px;border-top:1px solid rgba(255,255,255,.08);flex-shrink:0}
        .logout-form{display:flex;align-items:center}
        .logout-btn{display:flex;align-items:center;gap:8px;color:#a0b4cc;font-size:12px;font-family:Arial,sans-serif;cursor:pointer;background:none;border:none;padding:0}
        .logout-btn:hover{color:#e8c84a}

        /* MAIN */
        .main{margin-left:240px;flex:1;display:flex;flex-direction:column;min-height:100vh}
        .topbar{background:#fff;padding:0 28px;height:56px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e0e4ec;position:sticky;top:0;z-index:50;flex-shrink:0}
        .breadcrumb-nav{font-size:12px;color:#aaa;font-family:Arial,sans-serif}
        .breadcrumb-nav span{color:#0d1f3c;font-weight:600}
        .topbar-right{display:flex;align-items:center;gap:10px}
        .admin-badge{background:#0d1f3c;color:#e8c84a;font-size:11px;padding:4px 12px;border-radius:20px;font-family:Arial,sans-serif;font-weight:700}
        .view-site-btn{background:#e8c84a;color:#0d1f3c;font-size:12px;padding:6px 14px;border-radius:3px;border:none;cursor:pointer;font-weight:700;font-family:Arial,sans-serif;text-decoration:none;display:inline-block}
        .view-site-btn:hover{background:#f5d55a;color:#0d1f3c}

        .content{padding:24px 28px;flex:1}

        /* STATS GRID */
        .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
        .stat-card{background:#fff;border-radius:6px;padding:18px 20px;border-left:4px solid #e8c84a;box-shadow:0 1px 4px rgba(0,0,0,.06)}
        .stat-card.blue{border-left-color:#0d1f3c}
        .stat-card.green{border-left-color:#27ae60}
        .stat-card.red{border-left-color:#e74c3c}
        .stat-card .label{font-size:11px;color:#888;letter-spacing:1px;text-transform:uppercase;font-family:Arial,sans-serif;margin-bottom:6px}
        .stat-card .value{font-size:28px;font-weight:700;color:#0d1f3c}
        .stat-card .sub{font-size:11px;color:#aaa;font-family:Arial,sans-serif;margin-top:3px}

        /* MINI STATS (page level) */
        .mini-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
        .mini-stat{background:#fff;border-radius:6px;padding:14px 16px;border-left:3px solid #e8c84a;box-shadow:0 1px 3px rgba(0,0,0,.05)}
        .mini-stat.blue{border-left-color:#0d1f3c}
        .mini-stat.green{border-left-color:#27ae60}
        .mini-stat.red{border-left-color:#e74c3c}
        .mini-stat.purple{border-left-color:#8e44ad}
        .mini-stat .num{font-size:22px;font-weight:700;color:#0d1f3c}
        .mini-stat .lbl{font-size:10px;color:#999;font-family:Arial,sans-serif;letter-spacing:.8px;text-transform:uppercase;margin-top:2px}
        .mini-stat .trend{font-size:11px;color:#27ae60;font-family:Arial,sans-serif;margin-top:3px;font-weight:600}

        /* PAGE HEADER */
        .page-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px}
        .page-title{font-size:22px;color:#0d1f3c;font-weight:700}
        .page-sub{font-size:12px;color:#888;font-family:Arial,sans-serif;margin-top:3px}

        /* TABLE CARD */
        .table-card{background:#fff;border-radius:6px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.06);margin-bottom:24px}
        .table-wrap{overflow-x:auto}
        table{width:100%;border-collapse:collapse}
        thead{background:#0d1f3c}
        thead th{color:#e8c84a;font-size:10px;letter-spacing:1.2px;text-transform:uppercase;padding:11px 16px;text-align:left;font-family:Arial,sans-serif;font-weight:600;white-space:nowrap}
        tbody tr{border-bottom:.5px solid #f0f0f0;transition:background .15s}
        tbody tr:last-child{border-bottom:none}
        tbody tr:hover{background:#fafbff}
        tbody td{padding:11px 16px;font-size:13px;color:#333;font-family:Arial,sans-serif;vertical-align:middle}

        /* BADGES */
        .badge{display:inline-block;font-size:10px;padding:3px 8px;border-radius:3px;font-weight:600;font-family:Arial,sans-serif}
        .badge.active{background:#d4edda;color:#155724}
        .badge.expired{background:#f8d7da;color:#721c24}
        .badge.upcoming{background:#d1ecf1;color:#0c5460}
        .badge.pending{background:#fff3cd;color:#856404}
        .badge.confirmed{background:#d4edda;color:#155724}
        .badge.draft{background:#fff3cd;color:#856404}
        .badge.published{background:#d4edda;color:#155724}
        .badge.new-badge{background:#fff3cd;color:#856404}
        .badge.declined{background:#f8d7da;color:#721c24}

        /* ACTION BUTTONS */
        .action-btn{font-size:11px;padding:4px 10px;border-radius:3px;border:none;cursor:pointer;font-family:Arial,sans-serif;font-weight:600;margin-right:4px;display:inline-block}
        .action-btn.edit{background:#e8f0ff;color:#0d1f3c}
        .action-btn.edit:hover{background:#d0e0ff}
        .action-btn.del{background:#ffeaea;color:#c0392b}
        .action-btn.del:hover{background:#ffcdcd}
        .action-btn.view{background:#f0f0f0;color:#333}
        .action-btn.copy{background:#e8f9e8;color:#1e7e34}
        .action-btn.mark{background:#e8f0ff;color:#0d1f3c}

        /* SECTION TITLE */
        .section-title{font-size:14px;font-weight:700;color:#0d1f3c;margin-bottom:14px;display:flex;align-items:center;justify-content:space-between}
        .add-btn{background:#0d1f3c;color:#fff;font-size:11px;padding:6px 14px;border-radius:3px;border:none;cursor:pointer;font-family:Arial,sans-serif;font-weight:600}
        .add-btn:hover{background:#1a3a6b}
        .add-btn.gold{background:#e8c84a;color:#0d1f3c}
        .add-btn.gold:hover{background:#f5d55a}

        /* FORMS */
        .form-preview{background:#fff;border-radius:6px;padding:20px;box-shadow:0 1px 4px rgba(0,0,0,.06)}
        .form-group{margin-bottom:12px}
        .form-group label{display:block;font-size:11px;color:#666;font-family:Arial,sans-serif;margin-bottom:4px;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
        .form-group input,.form-group select,.form-group textarea{width:100%;border:1.5px solid #dde;border-radius:3px;padding:8px 10px;font-size:12px;font-family:Arial,sans-serif;color:#333;transition:border-color .15s}
        .form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:#0d1f3c}
        .form-group textarea{resize:vertical;min-height:80px}
        .form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
        .submit-btn{background:#e8c84a;color:#0d1f3c;border:none;padding:9px 20px;font-size:12px;font-weight:700;border-radius:3px;cursor:pointer;font-family:Arial,sans-serif;width:100%;margin-top:4px}
        .submit-btn:hover{background:#f5d55a}
        .submit-btn.dark{background:#0d1f3c;color:#fff}
        .submit-btn.dark:hover{background:#1a3a6b}

        /* FILTER BAR */
        .filter-bar{display:flex;align-items:center;gap:8px;margin-bottom:16px;flex-wrap:wrap}
        .filter-btn{border:1.5px solid #dde;background:#fff;color:#555;padding:6px 14px;border-radius:20px;font-size:12px;font-family:Arial,sans-serif;cursor:pointer;font-weight:500}
        .filter-btn:hover{border-color:#0d1f3c;color:#0d1f3c}
        .filter-btn.active{border-color:#0d1f3c;background:#0d1f3c;color:#fff}

        /* ALERTS */
        .alert-success{background:#d4edda;border:1px solid #c3e6cb;color:#155724;padding:12px 18px;border-radius:5px;font-size:13px;margin-bottom:20px;font-family:Arial,sans-serif;font-weight:600}

        /* TOAST */
        #toast{position:fixed;bottom:24px;right:24px;background:#0d1f3c;color:#fff;padding:12px 20px;border-radius:5px;font-size:13px;font-family:Arial,sans-serif;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none;border-left:3px solid #e8c84a}
        #toast.show{opacity:1}

        /* TWO COL */
        .two-col{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px}
        .two-col-wide{display:grid;grid-template-columns:1fr 380px;gap:20px;align-items:start}
        .two-col-form{display:grid;grid-template-columns:1fr 360px;gap:20px;align-items:start}

        /* UPLOAD BOX */
        .upload-zone{border:2px dashed #c0cce0;border-radius:6px;padding:24px;text-align:center;cursor:pointer;background:#f8faff;transition:all .2s;margin-bottom:16px}
        .upload-zone:hover{border-color:#0d1f3c;background:#eef3ff}
        .upload-zone p{font-size:12px;color:#aaa;font-family:Arial,sans-serif;margin-top:6px}

        /* INFO BANNER */
        .info-banner{background:#e8f4fd;border:1px solid #b8d9f0;border-radius:5px;padding:12px 16px;margin-bottom:18px;display:flex;align-items:flex-start;gap:10px}
        .info-banner p{font-size:12px;color:#1a5276;font-family:Arial,sans-serif;line-height:1.6}

        /* EXPIRY BANNER */
        .warning-banner{background:#fff3cd;border:1px solid #ffc107;border-radius:5px;padding:12px 16px;margin-bottom:18px;font-size:12px;color:#856404;font-family:Arial,sans-serif}
    </style>
</head>
<body>

@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<!-- SIDEBAR -->
<div class="sidebar">
    <div class="sidebar-logo">
        <div class="logo-box">
            <img src="/images/c4comlogo.jpg" alt="CU4J Logo" />
        </div>
        <div class="logo-text">
            <span>CU4J Admin</span>
            <small>501(C)(3) PORTAL</small>
        </div>
    </div>

    <div class="sidebar-label">Main</div>
    <a href="/Admin/Dashboard" class="nav-item @(ctrl == "Dashboard" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
    </a>
    <a href="/Admin/Events" class="nav-item @(ctrl == "Events" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Events
    </a>
    <a href="/Admin/Documents" class="nav-item @(ctrl == "Documents" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Documents
    </a>
    <a href="/Admin/Opinion" class="nav-item @(ctrl == "Opinion" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Opinion &amp; Essays
    </a>
    <a href="/Admin/Newsletter" class="nav-item @(ctrl == "Newsletter" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        Subscribers
    </a>

    <div class="sidebar-label">Manage</div>
    <a href="/Admin/Submissions" class="nav-item @(ctrl == "Submissions" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Contact Messages
    </a>
    <a href="/Admin/Gallery" class="nav-item @(ctrl == "Gallery" || ctrl == "Slider" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
        Photo Gallery
    </a>
    <a href="/Admin/Zeffy" class="nav-item @(ctrl == "Zeffy" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        Donations — Zeffy
    </a>
    <a href="/Admin/Volunteers" class="nav-item @(ctrl == "Volunteers" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        Volunteers
    </a>
    <a href="/Admin/Settings" class="nav-item @(ctrl == "Settings" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        Site Settings
    </a>
    @if (Context.Session.GetString("AdminRole") == "super")
    {
    <a href="/Admin/Users" class="nav-item @(ctrl == "Users" ? "active" : "")">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/><path d="M16 3.13a4 4 0 010 7.75"/><path d="M21 21v-2a4 4 0 00-3-3.87"/></svg>
        Admin Users
    </a>
    }

    <div class="sidebar-footer">
        <form asp-area="Admin" asp-controller="Auth" asp-action="Logout" method="post" class="logout-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="logout-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Log Out
            </button>
        </form>
    </div>
</div>

<!-- MAIN -->
<div class="main">
    <div class="topbar">
        <div class="breadcrumb-nav">
            Admin / <span>@ViewData["Title"]</span>
        </div>
        <div class="topbar-right">
            @RenderSection("TopbarActions", required: false)
            <a href="/Admin/Users/ChangePassword" style="display:flex;align-items:center;gap:5px;color:#888;font-size:11px;font-family:Arial;font-weight:600;text-decoration:none;padding:5px 10px;border:1px solid #eee;border-radius:3px" title="Change Password">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                @(Context.Session.GetString("AdminUsername") ?? "Admin")
            </a>
            <a href="/" target="_blank" class="view-site-btn">View Live Site ↗</a>
        </div>
    </div>

    <div class="content">
        @if (TempData["Success"] != null)
        {
            <div class="alert-success">✓ @TempData["Success"]</div>
        }
        @RenderBody()
    </div>
</div>

<div id="toast"></div>

<script>
function showToast(msg, dur) {
    var t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(function(){ t.classList.remove('show'); }, dur || 2500);
}
function setFilter(btn, group) {
    var btns = document.querySelectorAll('[data-filter-group="' + group + '"]');
    btns.forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
}
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
