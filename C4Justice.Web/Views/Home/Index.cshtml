@model C4Justice.Web.Models.MailingListViewModel
@{
    ViewData["Title"] = "Home";
    ViewData["ActivePage"] = "Home";
    var sliderImages = ViewBag.SliderImages as List<C4Justice.Web.Models.SliderImage> ?? new();
    var cfg = ViewBag.Settings as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<!-- ═══════════════════════════════════════════════════
     HERO: SLIDER  +  QUICK LINKS SIDEBAR
═══════════════════════════════════════════════════ -->
<section class="hero-grid">

    <!-- ── Slider ── -->
    <div class="slider-area" id="heroSlider">
        @if (sliderImages.Any())
        {
            var i = 0;
            foreach (var img in sliderImages)
            {
                <div class="slide @(i == 0 ? "active" : "")" data-index="@i">
                    <div class="slide-bg" style="background-image:url('@img.ImageUrl');background-size:cover;background-position:center;"></div>
                    <div class="slide-caption">
                        @if (!string.IsNullOrWhiteSpace(img.Title))
                        { <h2>@img.Title</h2> }
                        @if (!string.IsNullOrWhiteSpace(img.Subtitle))
                        { <p>@img.Subtitle</p> }
                    </div>
                </div>
                i++;
            }
        }
        else
        {
            <div class="slide active">
                <div class="slide-bg gradient-1"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Political Justice</h2>
                    <p>Fighting against gerrymandering, voter suppression, and authoritarianism that stifles citizen rights and participation.</p>
                </div>
            </div>
            <div class="slide">
                <div class="slide-bg gradient-2"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Racial Justice</h2>
                    <p>Fighting against white supremacy and persistent racial disparities in criminal justice, the economy and healthcare.</p>
                </div>
            </div>
            <div class="slide">
                <div class="slide-bg gradient-3"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Economic Justice</h2>
                    <p>Fighting for equitable access to opportunities, resources and economic empowerment for all communities.</p>
                </div>
            </div>
            <div class="slide">
                <div class="slide-bg gradient-4"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Healthcare Justice</h2>
                    <p>Fighting to eliminate health disparities and ensure equal access to quality healthcare for all Americans.</p>
                </div>
            </div>
            <div class="slide">
                <div class="slide-bg gradient-5"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Environmental Justice</h2>
                    <p>Fighting to eliminate disproportionate environmental and health impacts on marginalized communities.</p>
                </div>
            </div>
            <div class="slide">
                <div class="slide-bg gradient-6"></div>
                <div class="slide-caption slide-caption-center">
                    <h2 class="slide-quote">&ldquo;United We Stand. Divided We Fall.&rdquo;</h2>
                    <p class="slide-attribution">&mdash; Communities United For Justice Fund</p>
                </div>
            </div>
        }

        <!-- Dots -->
        <div class="slider-dots" id="sliderDots"></div>

        <!-- Prev / Next -->
        <div class="slider-controls">
            <button class="slider-btn" id="slidePrev" aria-label="Previous slide">&#8249;</button>
            <button class="slider-btn" id="slideNext" aria-label="Next slide">&#8250;</button>
        </div>
    </div>

    <!-- ── Quick Links Sidebar ── -->
    <div class="quick-actions">
        <h4>Quick Links</h4>
        <a href="/Contact#mailing-list" class="qa-btn">Join Our Mailing List</a>
        <a href="https://link.clover.com/urlshortener/TscDTq" target="_blank" rel="noopener" class="qa-btn qa-donate">
            <i class="fas fa-heart me-1"></i> Donate Today
        </a>
        <a href="/Events" class="qa-btn">Upcoming Events</a>
        <a href="/Contact" class="qa-btn">Contact Us</a>
        <a href="/GetInvolved" class="qa-btn">Get Involved</a>
        <a href="/GetInvolved#volunteer" class="qa-btn">Volunteer Sign Up</a>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════
     TAGLINE BAR
═══════════════════════════════════════════════════ -->
<div class="tagline-bar">
    <h2>"United We Stand. Divided We Fall."</h2>
    <p>&mdash; Communities United For Justice Fund</p>
</div>

<!-- ═══════════════════════════════════════════════════
     IMPACT COUNTER STRIP
═══════════════════════════════════════════════════ -->
<div class="impact-strip">
    <div class="impact-inner">
        <div class="impact-item reveal">
            <span class="impact-num" data-target="501">0</span>
            <span class="impact-label">501(c)(3) Certified</span>
        </div>
        <div class="impact-item reveal reveal-d1">
            <span class="impact-num" data-target="5" data-suffix="+">0</span>
            <span class="impact-label">Years of Service</span>
        </div>
        <div class="impact-item reveal reveal-d2">
            <span class="impact-num" data-target="50" data-suffix="+">0</span>
            <span class="impact-label">Events Hosted</span>
        </div>
        <div class="impact-item reveal reveal-d3">
            <span class="impact-num" data-target="1000" data-suffix="+">0</span>
            <span class="impact-label">Community Members</span>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════
     ABOUT US  +  COLLAGE GRID
═══════════════════════════════════════════════════ -->
<div class="about-sec">

    <!-- Left: Text -->
    <div class="about-left">
        <div class="about-lbl reveal">About Us</div>
        <h2 class="reveal reveal-d1">Fighting for Political, Racial, Economic,<br>Healthcare &amp; Environmental Justice</h2>
        <p class="reveal reveal-d2">A 501(c)(3) nonprofit organization uniting grassroots communities to achieve social justice through collaboration.</p>
        <div class="checks">
            <div class="chk reveal reveal-d2"><span class="chk-icon">&#10003;</span> Direct Action &amp; Voter Engagement</div>
            <div class="chk reveal reveal-d3"><span class="chk-icon">&#10003;</span> Local, State &amp; Federal Advocacy</div>
            <div class="chk reveal reveal-d4"><span class="chk-icon">&#10003;</span> Year-Round Community Organizing</div>
        </div>
        <a href="/About" class="read-more-link reveal reveal-d5">Read Our Full Story &#8594;</a>
    </div>

    <!-- Right: Collage grid -->
    <div class="collage-grid reveal reveal-d1">
        <div class="ci at-photo-1" data-l="Political Justice"></div>
        <div class="ci at-photo-2" data-l="Racial Justice"></div>
        <div class="ci sp2 at-photo-3" data-l="Environmental &amp; Economic Justice"></div>
    </div>

</div>

@section Scripts {
<script>
(function(){
    const slider   = document.getElementById('heroSlider');
    const dotsWrap = document.getElementById('sliderDots');
    if (!slider) return;

    const slides = slider.querySelectorAll('.slide');
    let current = 0, timer;

    // Build dots
    slides.forEach((_, i) => {
        const d = document.createElement('button');
        d.className = 'slider-dot' + (i === 0 ? ' active' : '');
        d.setAttribute('aria-label', 'Slide ' + (i+1));
        d.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(d);
    });

    function goTo(n) {
        slides[current].classList.remove('active');
        dotsWrap.children[current].classList.remove('active');
        current = (n + slides.length) % slides.length;
        slides[current].classList.add('active');
        dotsWrap.children[current].classList.add('active');
        resetTimer();
    }

    function resetTimer() {
        clearInterval(timer);
        timer = setInterval(() => goTo(current + 1), 5000);
    }

    document.getElementById('slidePrev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('slideNext')?.addEventListener('click', () => goTo(current + 1));
    resetTimer();
})();

// ── Scroll Reveal ──
(function () {
    const els = document.querySelectorAll('.reveal');
    if (!els.length) return;
    const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if (e.isIntersecting) {
                e.target.classList.add('visible');
                io.unobserve(e.target);
            }
        });
    }, { threshold: 0.15 });
    els.forEach(el => io.observe(el));
})();

// ── Impact Counter ──
(function () {
    const nums = document.querySelectorAll('.impact-num[data-target]');
    if (!nums.length) return;
    const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if (!e.isIntersecting) return;
            const el = e.target;
            const target = +el.dataset.target;
            const suffix = el.dataset.suffix || '';
            const duration = 1400;
            const start = performance.now();
            function step(now) {
                const p = Math.min((now - start) / duration, 1);
                const ease = 1 - Math.pow(1 - p, 3);
                el.textContent = Math.floor(ease * target).toLocaleString() + suffix;
                if (p < 1) requestAnimationFrame(step);
            }
            requestAnimationFrame(step);
            io.unobserve(el);
        });
    }, { threshold: 0.5 });
    nums.forEach(n => io.observe(n));
})();
</script>
}
