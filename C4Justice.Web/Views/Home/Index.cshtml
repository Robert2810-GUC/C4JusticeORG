@model C4Justice.Web.Models.MailingListViewModel
@{
    ViewData["Title"] = "Home";
    ViewData["ActivePage"] = "Home";
    var sliderImages = ViewBag.SliderImages as List<C4Justice.Web.Models.SliderImage> ?? new();
    var cfg = ViewBag.Settings as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<!-- ═══════════════════════════════════════════════════
     HERO: SLIDER  +  QUICK LINKS SIDEBAR
═══════════════════════════════════════════════════ -->
<section class="hero-grid">

    <!-- ── Slider ── -->
    <div class="slider-area" id="heroSlider">
        @if (sliderImages.Any())
        {
            var i = 0;
            foreach (var img in sliderImages)
            {
                <div class="slide @(i == 0 ? "active" : "")" data-index="@i">
                    <div class="slide-bg" style="background-image:url('@img.ImageUrl');background-size:cover;background-position:center;"></div>
                    <div class="slide-caption">
                        @if (!string.IsNullOrWhiteSpace(img.Title))
                        { <h2>@img.Title</h2> }
                        @if (!string.IsNullOrWhiteSpace(img.Subtitle))
                        { <p>@img.Subtitle</p> }
                    </div>
                </div>
                i++;
            }
        }
        else
        {
            <div class="slide active">
                <div class="slide-bg gradient-1"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Political Justice</h2>
                    <p>Fighting gerrymandering, voter suppression, and authoritarianism together.</p>
                </div>
            </div>
            <div class="slide">
                <div class="slide-bg gradient-2"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Racial Justice</h2>
                    <p>Eliminating racial disparities in criminal justice, economy and healthcare.</p>
                </div>
            </div>
            <div class="slide">
                <div class="slide-bg gradient-3"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Economic Justice</h2>
                    <p>Fighting for equitable access to opportunities, resources and economic empowerment for all communities.</p>
                </div>
            </div>
            <div class="slide">
                <div class="slide-bg gradient-4"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Healthcare Justice</h2>
                    <p>Advocating for affordable, accessible healthcare for every community.</p>
                </div>
            </div>
            <div class="slide">
                <div class="slide-bg gradient-5"></div>
                <div class="slide-caption">
                    <span class="slide-label">Fighting for Justice</span>
                    <h2>United for Environmental Justice</h2>
                    <p>Fighting disproportionate environmental impacts on marginalized communities.</p>
                </div>
            </div>
        }

        <!-- Dots -->
        <div class="slider-dots" id="sliderDots"></div>

        <!-- Prev / Next -->
        <div class="slider-controls">
            <button class="slider-btn" id="slidePrev" aria-label="Previous slide">&#8249;</button>
            <button class="slider-btn" id="slideNext" aria-label="Next slide">&#8250;</button>
        </div>
    </div>

    <!-- ── Quick Links Sidebar ── -->
    <div class="quick-actions">
        <h4>Quick Links</h4>
        <a href="/Contact#mailing-list" class="qa-btn">Join Our Mailing List</a>
        <a href="https://link.clover.com/urlshortener/TscDTq" target="_blank" rel="noopener" class="qa-btn qa-donate">
            <i class="fas fa-heart me-1"></i> Donate Today
        </a>
        <a href="/Events" class="qa-btn">Upcoming Events</a>
        <a href="/Contact" class="qa-btn">Contact Us</a>
        <a href="/GetInvolved" class="qa-btn">Get Involved</a>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════
     TAGLINE BAR
═══════════════════════════════════════════════════ -->
<div class="tagline-bar">
    <h2>"United We Stand. Divided We Fall."</h2>
    <p>&mdash; Communities United For Justice Fund</p>
</div>

<!-- ═══════════════════════════════════════════════════
     ABOUT US  +  JUSTICE CATEGORY GRID
═══════════════════════════════════════════════════ -->
<section class="home-about-section">
    <div class="home-about-inner">

        <!-- Left: Text -->
        <div class="home-about-text">
            <span class="section-label">About Us</span>
            <h2>Fighting for Political, Racial, Economic, Healthcare &amp; Environmental Justice</h2>
            <p>A 501(c)(3) nonprofit organization uniting grassroots communities to achieve social justice through collaboration.</p>
            <div class="home-about-tags">
                <span><i class="fas fa-check me-1"></i>Direct Action &amp; Voter Engagement</span>
                <span><i class="fas fa-check me-1"></i>Local, State &amp; Federal Advocacy</span>
                <span><i class="fas fa-check me-1"></i>Year-Round Community Organizing</span>
            </div>
            <a href="/About" class="home-about-link">Read Our Full Story &rarr;</a>
        </div>

        <!-- Right: Justice category grid -->
        <div class="home-justice-grid">
            <div class="hjg-cell hjg-political">
                <div class="hjg-icon"><i class="fas fa-fist-raised"></i></div>
                <span class="hjg-label">Political Justice</span>
            </div>
            <div class="hjg-cell hjg-racial">
                <div class="hjg-icon"><i class="fas fa-scale-balanced"></i></div>
                <span class="hjg-label">Racial Justice</span>
            </div>
            <div class="hjg-cell hjg-env hjg-wide">
                <div class="hjg-icon"><i class="fas fa-earth-americas"></i></div>
                <span class="hjg-placeholder">Replace with Richard's photos</span>
                <span class="hjg-label">Environmental &amp; Economic Justice</span>
            </div>
        </div>

    </div>
</section>

@section Scripts {
<script>
(function(){
    const slider   = document.getElementById('heroSlider');
    const dotsWrap = document.getElementById('sliderDots');
    if (!slider) return;

    const slides = slider.querySelectorAll('.slide');
    let current = 0, timer;

    // Build dots
    slides.forEach((_, i) => {
        const d = document.createElement('button');
        d.className = 'slider-dot' + (i === 0 ? ' active' : '');
        d.setAttribute('aria-label', 'Slide ' + (i+1));
        d.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(d);
    });

    function goTo(n) {
        slides[current].classList.remove('active');
        dotsWrap.children[current].classList.remove('active');
        current = (n + slides.length) % slides.length;
        slides[current].classList.add('active');
        dotsWrap.children[current].classList.add('active');
        resetTimer();
    }

    function resetTimer() {
        clearInterval(timer);
        timer = setInterval(() => goTo(current + 1), 5000);
    }

    document.getElementById('slidePrev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('slideNext')?.addEventListener('click', () => goTo(current + 1));
    resetTimer();
})();
</script>
}
