@{
    ViewData["Title"] = "About Us";
    ViewData["ActivePage"] = "About";
}

@section Styles {
<style>
/* PAGE HERO */
.page-hero-about { background:var(--navy); padding:36px 0; border-bottom:3px solid var(--gold); }
.ph-bc { color:rgba(232,200,74,.7); font-size:11px; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px; }
.ph-h1 { color:#fff; font-size:28px; font-family:var(--font-head); margin-bottom:4px; }
.ph-p { color:#a0b8d8; font-size:14px; }

/* MAIN LAYOUT */
.about-main { display:grid; grid-template-columns:1fr 300px; gap:0; max-width:1400px; margin:0 auto; }
.about-content { padding:36px 24px; }
.sec-lbl { color:var(--gold); font-size:10px; letter-spacing:2px; text-transform:uppercase; margin-bottom:8px; font-weight:700; display:block; }
.about-content h2 { color:var(--navy); font-size:22px; font-family:var(--font-head); margin-bottom:14px; line-height:1.3; }
.about-content p { color:#444; font-size:14px; line-height:1.85; margin-bottom:12px; }
.about-content em { color:var(--navy-light); font-style:italic; }
.a-divider { width:100%; height:1px; background:#eee; margin:28px 0; }
.founder-card { display:flex; gap:18px; align-items:flex-start; background:#f0f4ff; border-left:4px solid var(--navy-light); padding:18px; margin-bottom:20px; border-radius:3px; }
.f-av { width:56px; height:56px; border-radius:50%; background:var(--navy); display:flex; align-items:center; justify-content:center; font-size:16px; font-weight:700; color:var(--gold); flex-shrink:0; font-family:var(--font-head); }
.f-name { color:var(--navy); font-size:14px; font-weight:700; margin-bottom:2px; font-family:var(--font-head); }
.f-title { color:var(--gold); font-size:11px; margin-bottom:6px; font-weight:700; }
.f-text { color:#555; font-size:13px; line-height:1.75; margin:0; }
.justice-row { display:flex; flex-wrap:wrap; gap:8px; margin:14px 0 20px; }
.jp { background:var(--navy); color:#fff; font-size:11px; padding:5px 12px; border-radius:20px; font-weight:600; border-left:3px solid var(--gold); }
.read-more { color:var(--gold); font-size:13px; font-weight:700; text-decoration:none; border-bottom:1px solid var(--gold); padding-bottom:1px; display:inline-block; margin-top:4px; }
.wwd { display:flex; flex-direction:column; gap:10px; margin-top:14px; }
.wwd-item { display:flex; gap:12px; align-items:flex-start; }
.wwd-num { width:26px; height:26px; border-radius:50%; background:var(--navy-light); color:#fff; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:2px; }
.wwd-item h4 { color:var(--navy); font-size:14px; font-weight:700; margin-bottom:2px; }
.wwd-item p { color:#666; font-size:13px; line-height:1.75; margin:0; }

/* SIDEBAR */
.about-sidebar { background:#f8f9fc; border-left:1px solid #dde; padding:28px 18px; display:flex; flex-direction:column; gap:18px; position:sticky; top:70px; align-self:start; }
.sb-card { background:#fff; border:1px solid #dde; border-radius:4px; border-top:3px solid var(--gold); padding:18px; }
.sb-card h4 { color:var(--navy); font-size:13px; font-weight:700; margin-bottom:6px; font-family:var(--font-head); }
.sb-card p { color:#666; font-size:12px; line-height:1.65; margin-bottom:10px; }
.sb-btn { display:block; background:var(--navy-light); color:#fff; text-align:center; padding:9px; font-size:12px; font-weight:700; border-radius:3px; cursor:pointer; border:none; width:100%; text-decoration:none; }
.sb-btn.gold { background:var(--gold); color:var(--navy); }
.sb-btn:hover { background:var(--navy); color:#fff; text-decoration:none; }
.sb-btn.gold:hover { background:#e8b820; color:var(--navy); }
.sb-form { display:flex; flex-direction:column; gap:6px; }
.sb-form input { padding:7px 10px; border:1px solid #dde; border-radius:3px; font-size:12px; color:#333; background:#fff; font-family:var(--font-body); }
.sb-form button { background:var(--gold); color:var(--navy); border:none; padding:8px; font-size:12px; font-weight:700; border-radius:3px; cursor:pointer; }
.sb-501 { background:var(--navy); color:#fff; border-radius:4px; padding:14px; text-align:center; }
.sb-501 .badge-501 { font-size:16px; font-weight:700; color:var(--gold); font-family:var(--font-head); display:block; margin-bottom:3px; }
.sb-501 p { color:#a0b8d8; font-size:11px; margin:0; }

/* PHOTO CAROUSEL */
.carousel-wrap { background:var(--navy); padding:24px 0; border-top:3px solid var(--gold); overflow:hidden; }
.carousel-label { color:#e8c84a; font-size:10px; letter-spacing:2px; text-transform:uppercase; font-weight:700; text-align:center; margin-bottom:16px; }
.carousel-track-wrap { overflow:hidden; width:100%; }
.carousel-track { display:flex; gap:12px; width:max-content; animation:scroll-photos 20s linear infinite; }
.carousel-track:hover { animation-play-state:paused; }
@@keyframes scroll-photos { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
.photo-card { width:220px; height:160px; border-radius:4px; flex-shrink:0; display:flex; align-items:flex-end; position:relative; overflow:hidden; border:2px solid rgba(232,200,74,.2); }
.pc-bg { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; }
.pc-bg svg { width:40px; height:40px; stroke:rgba(232,200,74,.3); fill:none; stroke-width:1; }
.pc-label { position:relative; z-index:2; width:100%; background:rgba(13,31,60,.8); color:#fff; font-size:10px; padding:6px 10px; font-weight:600; }
.pc-hint { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); color:rgba(255,255,255,.2); font-size:9px; font-style:italic; text-align:center; z-index:1; width:100%; padding:0 10px; }
.pc1{background:#0d1f3c}.pc2{background:#281848}.pc3{background:#183828}.pc4{background:#482808}.pc5{background:#0a2848}.pc6{background:#182848}

@@media(max-width:767px){
    .about-main { grid-template-columns:1fr; }
    .about-sidebar { border-left:none; border-top:1px solid #dde; position:static; }
}
</style>
}

<!-- PAGE HERO -->
<div class="page-hero-about">
    <div style="max-width:1400px;margin:0 auto;padding:0 24px;">
        <div class="ph-bc">Home &rsaquo; About Us</div>
        <h1 class="ph-h1">About Us</h1>
        <p class="ph-p">United We Stand. Divided We Fall. — Communities United For Justice Fund</p>
    </div>
</div>

<!-- MAIN CONTENT + SIDEBAR -->
<div class="about-main">
  <div class="about-content">
    <span class="sec-lbl">Who We Are</span>
    <h2>Building a Platform for Justice</h2>
    <p>Communities United for Justice was formed to create a social justice advocacy platform that recognizes and encourages the oppressed, suppressed and marginalized to join forces to achieve common objectives through collaboration.</p>
    <p>For too long, grassroots organizations have advocated in silos on behalf of marginalized communities when all our social justice issues have a common thread: <em>that all individuals be treated with fairness and equity.</em></p>
    <div class="a-divider"></div>

    <span class="sec-lbl">Our Founder</span>
    <h2>The Architect of Collaboration</h2>
    <div class="founder-card">
        <div class="f-av">RR</div>
        <div>
            <div class="f-name">Mr. Richard Rose</div>
            <div class="f-title">Founder &amp; Executive Director</div>
            <p class="f-text">The architect of a successful collaborative strategy across three election cycles, Mr. Rose formed Communities United for Justice to combine grassroots power with a state-of-the-art technology platform for civic engagement to transform community outreach.</p>
        </div>
    </div>
    <div class="a-divider"></div>

    <span class="sec-lbl">What We Fight For</span>
    <h2>Fighting for Political, Racial, Economic, Healthcare &amp; Environmental Justice</h2>
    <div class="justice-row">
        <span class="jp">Political Justice</span>
        <span class="jp">Racial Justice</span>
        <span class="jp">Economic Justice</span>
        <span class="jp">Healthcare Justice</span>
        <span class="jp">Environmental Justice</span>
    </div>
    <a class="read-more" href="/Issues">Read Our Full Mission &rarr;</a>
    <div class="a-divider"></div>

    <span class="sec-lbl">What We Do</span>
    <h2>Our Actions &amp; Programs</h2>
    <div class="wwd">
        <div class="wwd-item">
            <div class="wwd-num">1</div>
            <div><h4>Direct Action &amp; Voter Engagement</h4><p>Mobilizing communities through direct action campaigns on local, state and federal levels.</p></div>
        </div>
        <div class="wwd-item">
            <div class="wwd-num">2</div>
            <div><h4>Legislative Engagement</h4><p>Advocating for policy change through targeted legislative engagement on all levels of government.</p></div>
        </div>
        <div class="wwd-item">
            <div class="wwd-num">3</div>
            <div><h4>Year-Round Community Organizing</h4><p>Organizing local communities for sustained, year-round advocacy beyond election cycles.</p></div>
        </div>
        <div class="wwd-item">
            <div class="wwd-num">4</div>
            <div><h4>Voter Education on Issues &amp; Elections</h4><p>Educating voters on key issues, candidates and elections to empower informed decision-making.</p></div>
        </div>
    </div>
  </div>

  <!-- SIDEBAR -->
  <div class="about-sidebar">
    <div class="sb-card">
        <h4>&#10084; Donate Today</h4>
        <p>Support our 501(c)(3) fund. Your donation is tax deductible.</p>
        <a href="/GetInvolved#donate" class="sb-btn gold">Donate Now</a>
    </div>
    <div class="sb-card">
        <h4>Volunteer</h4>
        <p>Join our volunteer network and contribute your time and skills to the movement.</p>
        <a href="/GetInvolved" class="sb-btn">Sign Up to Volunteer</a>
    </div>
    <div class="sb-card">
        <h4>Speaker Request</h4>
        <p>Invite us to speak at your next event, town hall, or community meeting.</p>
        <a href="/GetInvolved#speaker" class="sb-btn">Request a Speaker</a>
    </div>
    <div class="sb-card">
        <h4>Join Our Newsletter</h4>
        <p>Stay informed on events and ways to get involved.</p>
        <div class="sb-form">
            <input type="text" placeholder="Full Name"/>
            <input type="email" placeholder="Email Address"/>
            <input type="tel" placeholder="Mobile Phone"/>
            <input type="text" placeholder="Zip Code"/>
            <button>Subscribe</button>
        </div>
    </div>
    <div class="sb-501">
        <span class="badge-501">501(c)(3)</span>
        <p>Certified Nonprofit Organization<br>Donations are tax deductible</p>
    </div>
  </div>
</div>

<!-- AUTO-SCROLLING PHOTO CAROUSEL -->
<div class="carousel-wrap">
  <div class="carousel-label">Our Community in Action — Photos Coming Soon</div>
  <div class="carousel-track-wrap">
    <div class="carousel-track">
      <div class="photo-card pc1"><div class="pc-bg"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Community Events</div></div>
      <div class="photo-card pc2"><div class="pc-bg"><svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Voter Registration</div></div>
      <div class="photo-card pc3"><div class="pc-bg"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Town Halls</div></div>
      <div class="photo-card pc4"><div class="pc-bg"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Advocacy &amp; Action</div></div>
      <div class="photo-card pc5"><div class="pc-bg"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Environmental Action</div></div>
      <div class="photo-card pc6"><div class="pc-bg"><svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Economic Justice</div></div>
      <!-- Duplicate for seamless loop -->
      <div class="photo-card pc1"><div class="pc-bg"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Community Events</div></div>
      <div class="photo-card pc2"><div class="pc-bg"><svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Voter Registration</div></div>
      <div class="photo-card pc3"><div class="pc-bg"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Town Halls</div></div>
      <div class="photo-card pc4"><div class="pc-bg"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Advocacy &amp; Action</div></div>
      <div class="photo-card pc5"><div class="pc-bg"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Environmental Action</div></div>
      <div class="photo-card pc6"><div class="pc-bg"><svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/></svg></div><div class="pc-hint">Community photo</div><div class="pc-label">Economic Justice</div></div>
    </div>
  </div>
</div>
