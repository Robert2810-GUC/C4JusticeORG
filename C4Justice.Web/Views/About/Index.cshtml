<!-- ── MEET THE FOUNDER ── -->
<section class="py-section" style="background:var(--white);">
    <div class="container-xl">
        <div class="row align-items-center gy-4">
            <div class="col-lg-3 text-center">
                <div class="founder-avatar">
                    <i class="fas fa-user-tie"></i>
                </div>
                <div class="founder-badge">Founder &amp; Architect</div>
            </div>
            <div class="col-lg-9">
                <div class="section-header">
                    <span class="section-label">Our Founder</span>
                    <h2 class="section-title">Richard Rose</h2>
                </div>
                <p class="lead-text">
                    Mr. Richard Rose is the architect of a successful collaborative strategy that has mobilized
