<!-- ── FIVE PILLARS OF JUSTICE ── -->
<section class="py-section" style="background:var(--navy);">
    <div class="container-xl">
        <div class="section-header text-center mb-5">
            <span class="section-label light">Our Causes</span>
            <h2 class="section-title light">Fighting for Justice on All Fronts</h2>
            <p class="section-subtitle" style="color:rgba(255,255,255,0.7);">
                Five pillars of advocacy that guide our work toward a more equitable society.
            </p>
        </div>

        <div class="pillars-timeline">

            <!-- ① Political Justice -->
            <div id="political" class="pillar-row">
                <div class="pillar-row-number" style="background:#1B4F91;border-color:rgba(255,255,255,0.25);">
                    <i class="fas fa-landmark"></i>
                    <span>01</span>
                </div>
                <div class="pillar-row-content">
                    <h3>Political Justice</h3>
                    <p>
                        We believe that the rights proclaimed in the Constitution must be applied fairly and equitably
                        to all citizens. We fight against the injustice of <strong>gerrymandering</strong>,
                        <strong>voter suppression</strong>, and <strong>authoritarianism</strong> that stifle citizen
                        rights and participation.
                    </p>
                    <div class="pillar-tags">
                        <span class="pillar-tag">Voter Rights</span>
                        <span class="pillar-tag">Anti-Gerrymandering</span>
                        <span class="pillar-tag">Constitutional Rights</span>
                        <span class="pillar-tag">Civic Participation</span>
                    </div>
                </div>
            </div>

            <!-- ② Racial Justice -->
            <div id="racial" class="pillar-row">
                <div class="pillar-row-number" style="background:#b91c1c;border-color:rgba(255,255,255,0.25);">
                    <i class="fas fa-people-group"></i>
                    <span>02</span>
                </div>
                <div class="pillar-row-content">
                    <h3>Racial Justice</h3>
                    <p>
                        We fight against the resurgence of white supremacy and the violent assault on communities of color.
                        We seek to eliminate persistent racial disparities in the <strong>criminal justice system</strong>,
                        the <strong>economy and jobs</strong>, and <strong>healthcare</strong>.
                    </p>
                    <div class="pillar-tags">
                        <span class="pillar-tag">Anti-Discrimination</span>
                        <span class="pillar-tag">Criminal Justice Reform</span>
                        <span class="pillar-tag">Healthcare Equity</span>
                        <span class="pillar-tag">Economic Opportunity</span>
                    </div>
                </div>
            </div>

            <!-- ③ Economic Justice -->
            <div id="economic" class="pillar-row">
                <div class="pillar-row-number" style="background:#d97706;border-color:rgba(255,255,255,0.25);">
                    <i class="fas fa-scale-balanced"></i>
                    <span>03</span>
                </div>
                <div class="pillar-row-content">
                    <h3>Economic Justice</h3>
                    <p>
                        The economy will be more successful when all citizens have opportunities to thrive and reach their
                        full potential. We fight against <strong>disinvestment</strong>, <strong>red-lining</strong>,
                        and <strong>glass ceilings</strong> — advocating for equitable access to opportunities and resources.
                    </p>
                    <div class="pillar-tags">
                        <span class="pillar-tag">Fair Wages</span>
                        <span class="pillar-tag">Anti-Redlining</span>
                        <span class="pillar-tag">Equal Opportunity</span>
                        <span class="pillar-tag">Community Investment</span>
                    </div>
                </div>
            </div>

            <!-- ④ Healthcare Justice -->
            <div id="healthcare" class="pillar-row">
                <div class="pillar-row-number" style="background:#dc2626;border-color:rgba(255,255,255,0.25);">
                    <i class="fas fa-heart-pulse"></i>
                    <span>04</span>
                </div>
                <div class="pillar-row-content">
                    <h3>Healthcare Justice</h3>
                    <p>
                        We fight for equitable access to quality healthcare for all communities, regardless of race,
                        income, or zip code. We work to eliminate <strong>systemic disparities</strong> in health
                        outcomes, expand <strong>coverage and affordability</strong>, and address the social
                        determinants of health.
                    </p>
                    <div class="pillar-tags">
                        <span class="pillar-tag">Healthcare Access</span>
                        <span class="pillar-tag">Health Equity</span>
                        <span class="pillar-tag">Affordable Coverage</span>
                        <span class="pillar-tag">Mental Health</span>
                    </div>
                </div>
            </div>

            <!-- ⑤ Environmental Justice -->
            <div id="environmental" class="pillar-row">
                <div class="pillar-row-number" style="background:#16a34a;border-color:rgba(255,255,255,0.25);">
                    <i class="fas fa-leaf"></i>
                    <span>05</span>
                </div>
                <div class="pillar-row-content">
                    <h3>Environmental Justice</h3>
                    <p>
                        We fight to eliminate the disproportionate economic and health impacts of
                        <strong>environmental hazards</strong> and <strong>climate change</strong> on marginalized
                        communities. Every community deserves clean air, clean water, and a healthy environment.
                    </p>
                    <div class="pillar-tags">
                        <span class="pillar-tag">Clean Environment</span>
                        <span class="pillar-tag">Climate Action</span>
                        <span class="pillar-tag">Health Protection</span>
                        <span class="pillar-tag">Community Health</span>
                    </div>
                </div>
            </div>

        </div><!-- /.pillars-timeline -->
    </div>
</section>

