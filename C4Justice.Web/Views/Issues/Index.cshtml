@inject C4Justice.Web.Data.AppDbContext _settingsDb
@{ var _donateUrl = _settingsDb.SiteSettings.FirstOrDefault(s => s.Key == "zeffy_form_url")?.Value; if (string.IsNullOrWhiteSpace(_donateUrl)) _donateUrl = "@_donateUrl"; }
@{
    ViewData["Title"] = "Focus Areas";
    ViewData["ActivePage"] = "Issues";
}

<!-- Page Hero -->
<section class="page-hero">
    <div class="page-hero-content">
        <span class="page-hero-label">What We Fight For</span>
        <h1 class="page-hero-title">Our Focus Areas</h1>
        <p class="page-hero-sub">Championing justice across every dimension of community life.</p>
        <nav aria-label="breadcrumb" class="page-hero-breadcrumb mt-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active">Focus Areas</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Issues Grid -->
<section class="py-section" style="background:var(--white);">
    <div class="container-xl">
        <div class="section-header text-center mb-5">
            <span class="section-label">Five Pillars</span>
            <h2 class="section-title">Fighting for Justice</h2>
            <p class="section-subtitle">Our mission spans five critical areas where we work to create meaningful change for marginalized communities.</p>
        </div>
        <div class="issues-grid">
            <div class="issue-card pillar-political">
                <div class="issue-icon"><i class="fas fa-landmark"></i></div>
                <h4>Political Justice</h4>
                <p>Advocating for fair representation, voting rights, and democratic accountability for all communities.</p>
                <a href="/Mission" class="issue-link">Learn More →</a>
            </div>
            <div class="issue-card pillar-racial">
                <div class="issue-icon"><i class="fas fa-people-group"></i></div>
                <h4>Racial Justice</h4>
                <p>Confronting systemic racism, dismantling structural inequities, and building an equitable society.</p>
                <a href="/Mission" class="issue-link">Learn More →</a>
            </div>
            <div class="issue-card pillar-economic">
                <div class="issue-icon"><i class="fas fa-scale-balanced"></i></div>
                <h4>Economic Justice</h4>
                <p>Closing wealth gaps, ensuring fair wages, and creating economic opportunity for marginalized communities.</p>
                <a href="/Mission" class="issue-link">Learn More →</a>
            </div>
            <div class="issue-card pillar-healthcare">
                <div class="issue-icon"><i class="fas fa-heart-pulse"></i></div>
                <h4>Healthcare Justice</h4>
                <p>Fighting for equitable access to quality healthcare and eliminating systemic health disparities.</p>
                <a href="/Mission" class="issue-link">Learn More →</a>
            </div>
            <div class="issue-card pillar-environmental">
                <div class="issue-icon"><i class="fas fa-leaf"></i></div>
                <h4>Environmental Justice</h4>
                <p>Protecting vulnerable communities from environmental hazards and advancing climate equity.</p>
                <a href="/Mission" class="issue-link">Learn More →</a>
            </div>
        </div>
    </div>
</section>

<!-- Get Involved CTA -->
<section class="cta-section">
    <div class="container-xl">
        <div class="section-header text-center mb-5">
            <span class="section-label light">Join Us</span>
            <h2 class="section-title light">Ready to Make a Difference?</h2>
            <p class="section-subtitle" style="color:rgba(255,255,255,0.7);">Support our work across all five pillars of justice.</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="cta-card">
                    <div class="cta-card-icon"><i class="fas fa-hands-helping"></i></div>
                    <h4>Volunteer</h4>
                    <p>Give your time and skills to support our advocacy and community efforts.</p>
                    <a href="/GetInvolved" class="cta-card-link">Get Started →</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="cta-card">
                    <div class="cta-card-icon"><i class="fas fa-heart"></i></div>
                    <h4>Donate</h4>
                    <p>Your tax-deductible contribution directly supports our mission for justice.</p>
                    <a href="@_donateUrl" target="_blank" rel="noopener" class="cta-card-link">Donate Now →</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="cta-card">
                    <div class="cta-card-icon"><i class="fas fa-pen-nib"></i></div>
                    <h4>Read Our Articles</h4>
                    <p>Stay informed with opinion pieces and analysis from our community advocates.</p>
                    <a href="/Opinion" class="cta-card-link">Read Now →</a>
                </div>
            </div>
        </div>
    </div>
</section>
