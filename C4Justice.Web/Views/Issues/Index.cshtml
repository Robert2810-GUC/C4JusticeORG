@{
    ViewData["Title"] = "Focus Areas";
}

<!-- Page Hero -->
<section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="container text-center">
        <h1 class="page-hero-title" data-aos="fade-down">Our Focus Areas</h1>
        <p class="page-hero-subtitle" data-aos="fade-up" data-aos-delay="100">
            Championing justice across every dimension of community life
        </p>
    </div>
</section>

<!-- Issues Grid -->
<section class="section-padding">
    <div class="container">
        <div class="row g-4">

            <div class="col-lg-4 col-md-6" data-aos="fade-up">
                <div class="stub-card">
                    <div class="stub-icon" style="background: rgba(59,130,246,0.15); color: #3b82f6;">
                        <i class="fas fa-landmark"></i>
                    </div>
                    <h3 class="stub-title">Political Justice</h3>
                    <p class="stub-desc">Advocating for fair representation, voting rights, and democratic accountability for all communities.</p>
                    <a href="/About#political" class="btn-c4j-outline">Learn More</a>
                </div>
            </div>

            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="stub-card">
                    <div class="stub-icon" style="background: rgba(185,28,28,0.15); color: #b91c1c;">
                        <i class="fas fa-people-group"></i>
                    </div>
                    <h3 class="stub-title">Racial Justice</h3>
                    <p class="stub-desc">Confronting systemic racism, dismantling structural inequities, and building an equitable society.</p>
                    <a href="/About#racial" class="btn-c4j-outline">Learn More</a>
                </div>
            </div>

            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="stub-card">
                    <div class="stub-icon" style="background: rgba(217,119,6,0.15); color: #d97706;">
                        <i class="fas fa-scale-balanced"></i>
                    </div>
                    <h3 class="stub-title">Economic Justice</h3>
                    <p class="stub-desc">Closing wealth gaps, ensuring fair wages, and creating economic opportunity for marginalized communities.</p>
                    <a href="/About#economic" class="btn-c4j-outline">Learn More</a>
                </div>
            </div>

            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="stub-card">
                    <div class="stub-icon" style="background: rgba(14,165,233,0.15); color: #0ea5e9;">
                        <i class="fas fa-heart-pulse"></i>
                    </div>
                    <h3 class="stub-title">Healthcare Justice</h3>
                    <p class="stub-desc">Fighting for equitable access to quality healthcare and eliminating systemic health disparities.</p>
                    <a href="/About#healthcare" class="btn-c4j-outline">Learn More</a>
                </div>
            </div>

            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="stub-card">
                    <div class="stub-icon" style="background: rgba(22,163,74,0.15); color: #16a34a;">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <h3 class="stub-title">Environmental Justice</h3>
                    <p class="stub-desc">Protecting vulnerable communities from environmental hazards and advancing climate equity.</p>
                    <a href="/About#environmental" class="btn-c4j-outline">Learn More</a>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 d-flex align-items-center justify-content-center" data-aos="fade-up" data-aos-delay="500">
                <div class="text-center p-4">
                    <p class="mb-3" style="color: var(--c4-text-muted);">More detailed content and articles coming soon.</p>
                    <a href="/GetInvolved" class="btn-c4j">Get Involved</a>
                </div>
            </div>

        </div>
    </div>
</section>
