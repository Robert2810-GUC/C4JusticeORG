@{
    ViewData["Title"] = "Events";
    ViewData["ActivePage"] = "Events";
    var upcoming = ViewBag.UpcomingEvents as List<C4Justice.Web.Models.SiteEvent> ?? new();
    var past = ViewBag.PastEvents as List<C4Justice.Web.Models.SiteEvent> ?? new();
}

@section Styles {
<style>
.page-hero-ev{background:var(--navy);padding:36px 0;border-bottom:3px solid var(--gold);}
.ph-bc{color:rgba(232,200,74,.7);font-size:11px;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;}
.ph-h1{color:#fff;font-size:28px;font-family:var(--font-head);margin-bottom:4px;}
.ph-p{color:#a0b8d8;font-size:14px;}

.ev-main{display:grid;grid-template-columns:1fr 300px;gap:0;align-items:start;max-width:1400px;margin:0 auto;}
.ev-content{padding:36px 24px;}
.sec-lbl{color:var(--gold);font-size:10px;letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;font-weight:700;display:block;}
.ev-content h2{color:var(--navy);font-size:22px;font-family:var(--font-head);margin-bottom:20px;line-height:1.3;}

/* COMPACT CARD GRID */
.events-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.ev-card{background:#fff;border:1px solid #dde;border-radius:8px;overflow:hidden;transition:box-shadow .25s,transform .25s;display:flex;flex-direction:column;box-shadow:0 2px 8px rgba(13,31,60,.06);}
.ev-card:hover{box-shadow:0 10px 28px rgba(13,31,60,.16);transform:translateY(-3px);}
.ev-card.soon{border-bottom:3px solid #e85a1a;}
.ev-card.upcoming-card{border-bottom:3px solid var(--gold);}

/* Card date header — gradient + decorative circles */
.ev-card-head{
    background:linear-gradient(135deg,#0d1f3c 0%,#1a3a6b 60%,#0f2d50 100%);
    padding:22px 18px 18px;
    display:flex;align-items:flex-start;justify-content:space-between;
    position:relative;overflow:hidden;min-height:100px;
}
.ev-card-head::before{
    content:'';position:absolute;top:-28px;right:-28px;
    width:90px;height:90px;border-radius:50%;
    background:rgba(232,200,74,.08);
}
.ev-card-head::after{
    content:'';position:absolute;bottom:-18px;right:18px;
    width:55px;height:55px;border-radius:50%;
    background:rgba(232,200,74,.05);
}
.ev-day{font-size:42px;font-weight:700;color:#e8c84a;line-height:1;font-family:var(--font-head);text-shadow:0 2px 8px rgba(0,0,0,.3);}
.ev-month-year{font-size:11px;color:rgba(232,200,74,.85);text-transform:uppercase;letter-spacing:1px;margin-top:4px;font-weight:600;}
.ev-date-block{display:flex;flex-direction:column;position:relative;z-index:1;}
.ev-status-pill{font-size:10px;font-weight:700;padding:4px 10px;border-radius:20px;align-self:flex-start;white-space:nowrap;position:relative;z-index:1;letter-spacing:.3px;}
.ev-status-pill.soon{background:#e85a1a;color:#fff;box-shadow:0 2px 6px rgba(232,90,26,.4);}
.ev-status-pill.upcoming{background:#1aa01a;color:#fff;box-shadow:0 2px 6px rgba(26,160,26,.35);}

/* Card body */
.ev-card-body{padding:18px;flex:1;display:flex;flex-direction:column;}
.ev-card-title{color:#0d1f3c;font-size:15px;font-weight:700;font-family:var(--font-head);margin-bottom:10px;line-height:1.35;}
.ev-card-meta{display:flex;flex-direction:column;gap:6px;margin-bottom:12px;}
.ev-meta-row{display:flex;align-items:center;gap:6px;color:#555;font-size:12px;}
.ev-meta-row svg{width:12px;height:12px;stroke:#1a3a6b;fill:none;stroke-width:2;flex-shrink:0;opacity:.7;}
.ev-card-desc{color:#444;font-size:13px;line-height:1.65;margin-bottom:12px;flex:1;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;}
.ev-card-footer{display:flex;align-items:center;justify-content:space-between;margin-top:auto;padding-top:12px;border-top:1px solid #eef;}
.ev-cat-badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:3px;background:#e8f0ff;color:#0d1f3c;text-transform:uppercase;letter-spacing:.3px;}
.ev-cat-badge.voter{background:#e8f5e9;color:#1b5e20;}
.ev-cat-badge.health{background:#fce4ec;color:#880e4f;}
.ev-cat-badge.env{background:#e0f7fa;color:#006064;}
.ev-cat-badge.political{background:#fef9e7;color:#7d6608;}
.ev-learn-btn{font-size:11px;font-weight:700;color:#fff;background:#0d1f3c;border:none;padding:6px 14px;border-radius:3px;cursor:pointer;text-decoration:none;transition:all .15s;}
.ev-learn-btn:hover{background:#e8c84a;color:#0d1f3c;text-decoration:none;}
.ev-learn-btn.no-link{background:#f5f5f5;color:#bbb;cursor:default;}
.ev-learn-btn.no-link:hover{background:#f5f5f5;color:#bbb;}

.no-events{text-align:center;padding:32px;background:#f8f9fc;border-radius:4px;border:1px dashed #dde;}
.no-events p{color:#888;font-size:13px;}

/* Election section */
.election-sec{margin-top:36px;padding-top:28px;border-top:1px solid #eee;}
.election-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:16px;}
.election-card{background:#f0f4ff;border:1px solid #dde;border-radius:4px;padding:16px;border-top:3px solid var(--navy-light);}
.election-card h4{color:var(--navy);font-size:13px;font-weight:700;margin-bottom:6px;font-family:var(--font-head);}
.election-card p{color:#666;font-size:12px;line-height:1.65;margin-bottom:6px;}
.election-date{color:#e8c84a;font-size:11px;font-weight:700;}

/* Sidebar */
.ev-sidebar{background:#f8f9fc;border-left:1px solid #dde;padding:28px 18px;display:flex;flex-direction:column;gap:18px;align-self:start;position:sticky;top:70px;}
.sb-card{background:#fff;border:1px solid #dde;border-radius:4px;border-top:3px solid var(--gold);padding:18px;}
.sb-card h4{color:var(--navy);font-size:13px;font-weight:700;margin-bottom:8px;font-family:var(--font-head);}
.sb-card p{color:#666;font-size:12px;line-height:1.65;margin-bottom:10px;}
.sb-btn{display:block;background:var(--navy-light);color:#fff;text-align:center;padding:9px;font-size:12px;font-weight:700;border-radius:3px;cursor:pointer;border:none;width:100%;margin-bottom:8px;text-decoration:none;}
.sb-btn:hover{background:var(--navy);color:#fff;text-decoration:none;}
.sb-btn.gold{background:var(--gold);color:var(--navy);}
.sb-btn.gold:hover{background:#e8b820;}
.upcoming-list{display:flex;flex-direction:column;gap:10px;}
.ul-item{display:flex;gap:10px;align-items:flex-start;padding-bottom:10px;border-bottom:.5px solid #eee;}
.ul-item:last-child{border-bottom:none;padding-bottom:0;}
.ul-date{background:#0d1f3c;color:#e8c84a;font-size:9px;font-weight:700;padding:4px 6px;border-radius:3px;text-align:center;flex-shrink:0;line-height:1.4;min-width:36px;}
.ul-info h5{color:#0d1f3c;font-size:11px;font-weight:700;margin-bottom:2px;}
.ul-info p{color:#888;font-size:10px;margin:0;}
.sb-501{background:var(--navy);color:#fff;border-radius:4px;padding:14px;text-align:center;}
.sb-501 .badge-501{font-size:16px;font-weight:700;color:var(--gold);font-family:var(--font-head);display:block;margin-bottom:3px;}
.sb-501 p{color:#a0b8d8;font-size:11px;margin:0;}

@@media(max-width:900px){.events-grid{grid-template-columns:repeat(2,1fr);}}
@@media(max-width:767px){.ev-main{grid-template-columns:1fr;}.ev-sidebar{border-left:none;border-top:1px solid #dde;position:static;}.election-grid{grid-template-columns:1fr;}.events-grid{grid-template-columns:1fr;}}
</style>
}

<!-- PAGE HERO -->
<div class="page-hero-ev">
    <div style="max-width:1400px;margin:0 auto;padding:0 24px;">
        <div class="ph-bc">Home &rsaquo; Events</div>
        <h1 class="ph-h1">Events</h1>
        <p class="ph-p">Join us at upcoming community events, rallies and voter education sessions.</p>
    </div>
</div>

<div class="ev-main">
  <div class="ev-content">
    <span class="sec-lbl">Upcoming Events</span>
    <h2>Events &amp; Community Actions</h2>

    @if (!upcoming.Any())
    {
        <div class="no-events">
            <p>No upcoming events at this time. Join our newsletter to be notified of new events.</p>
        </div>
    }
    else
    {
        <div class="events-grid">
        @foreach (var ev in upcoming)
        {
            var daysAway = (int)Math.Ceiling((ev.EventDate - DateTime.UtcNow).TotalDays);
            var isSoon = daysAway <= 7;
            var catClass = ev.Category == "Voter Registration" ? "voter"
                         : ev.Category == "Healthcare" ? "health"
                         : ev.Category == "Environmental" ? "env"
                         : ev.Category == "Political" ? "political" : "";
            <div class="ev-card @(isSoon ? "soon" : "upcoming-card")">
                <div class="ev-card-head">
                    <div class="ev-date-block">
                        <div class="ev-day">@ev.EventDate.Day</div>
                        <div class="ev-month-year">@ev.EventDate.ToString("MMM yyyy")</div>
                    </div>
                    <div class="ev-status-pill @(isSoon ? "soon" : "upcoming")">@(isSoon ? "This Week!" : "Upcoming")</div>
                </div>
                <div class="ev-card-body">
                    <div class="ev-card-title">@ev.Title</div>
                    <div class="ev-card-meta">
                        @if (!string.IsNullOrWhiteSpace(ev.Location))
                        {
                            <div class="ev-meta-row">
                                <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                @ev.Location
                            </div>
                        }
                        <div class="ev-meta-row">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            @(daysAway <= 0 ? "Today" : daysAway == 1 ? "Tomorrow" : daysAway + " days away")
                        </div>
                        @if (ev.EndDate.HasValue)
                        {
                            <div class="ev-meta-row">
                                <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                Ends @ev.EndDate.Value.ToString("MMM d, yyyy")
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(ev.Description))
                    {
                        <div class="ev-card-desc">@ev.Description</div>
                    }
                    <div class="ev-card-footer">
                        <span class="ev-cat-badge @catClass">@(ev.Category ?? "General")</span>
                        @if (!string.IsNullOrWhiteSpace(ev.RegisterUrl))
                        {
                            <a href="@ev.RegisterUrl" target="_blank" class="ev-learn-btn">Register &rarr;</a>
                        }
                        else
                        {
                            <span class="ev-learn-btn no-link">No Link</span>
                        }
                    </div>
                </div>
            </div>
        }
        </div>
    }

    <!-- ELECTION CYCLES -->
    <div class="scroll-anchor" id="election"></div>
    <div class="election-sec">
        <span class="sec-lbl">Election Cycles</span>
        <h2>Key Election Dates &amp; Information</h2>
        <p style="color:#555;font-size:13px;line-height:1.8;margin-bottom:16px">Stay informed on upcoming election cycles, registration deadlines and voting information for local, state and federal elections.</p>
        <div class="election-grid">
            <div class="election-card">
                <h4>Georgia Primary Elections</h4>
                <p>Primary election for state and local offices across Georgia.</p>
                <div class="election-date">May 21, 2026</div>
            </div>
            <div class="election-card">
                <h4>Voter Registration Deadline</h4>
                <p>Last day to register to vote for the upcoming primary elections.</p>
                <div class="election-date">April 21, 2026</div>
            </div>
            <div class="election-card">
                <h4>Federal Midterm Elections</h4>
                <p>Midterm elections for U.S. House and Senate seats.</p>
                <div class="election-date">November 3, 2026</div>
            </div>
            <div class="election-card">
                <h4>Early Voting Period</h4>
                <p>Early voting period for Georgia primary elections.</p>
                <div class="election-date">May 11–19, 2026</div>
            </div>
        </div>
    </div>
  </div>

  <!-- SIDEBAR -->
  <div class="ev-sidebar">
    <div class="sb-card">
        <h4>Upcoming Events</h4>
        @if (!upcoming.Any())
        {
            <p style="color:#888;font-size:11px;">No upcoming events.</p>
        }
        else
        {
            <div class="upcoming-list">
            @foreach (var ev in upcoming.Take(4))
            {
                <div class="ul-item">
                    <div class="ul-date">@ev.EventDate.Day<br/>@ev.EventDate.ToString("MMM")</div>
                    <div class="ul-info">
                        <h5>@ev.Title</h5>
                        <p>@(ev.Category ?? "Event") &bull; @((int)Math.Ceiling((ev.EventDate - DateTime.UtcNow).TotalDays)) days away</p>
                    </div>
                </div>
            }
            </div>
        }
    </div>
    <div class="sb-card">
        <h4>&#10084; Donate Today</h4>
        <p>Support our mission and help fund community events.</p>
        <a href="/GetInvolved#donate" class="sb-btn gold">Donate Now</a>
    </div>
    <div class="sb-card">
        <h4>Volunteer</h4>
        <p>Help organize and run our community events.</p>
        <a href="/GetInvolved" class="sb-btn">Sign Up to Volunteer</a>
    </div>
    <div class="sb-card">
        <h4>Join Our Newsletter</h4>
        <p>Get notified about upcoming events and community actions.</p>
        <a href="/GetInvolved#newsletter" class="sb-btn">Subscribe Now</a>
    </div>
    <div class="sb-501">
        <span class="badge-501">501(c)(3)</span>
        <p>Certified Nonprofit Organization<br>Donations are tax deductible</p>
    </div>
  </div>
</div>
