@{
    ViewData["Title"] = "Resources";
    ViewData["ActivePage"] = "Resources";
    var docs = ViewBag.Documents as List<C4Justice.Web.Models.SiteDocument> ?? new();
}

@section Styles {
<style>
.page-hero-res{background:#0d1f3c;padding:28px 2rem;border-bottom:3px solid #e8c84a;}
.ph-bc{color:rgba(232,200,74,.7);font-size:11px;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;}
.ph-h1{color:#fff;font-size:28px;font-family:Georgia,serif;margin-bottom:4px;}
.ph-p{color:#a0b8d8;font-size:13px;}
.tab-nav{background:#f0f4ff;border-bottom:2px solid #dde;padding:0 2rem;display:flex;gap:0;}
.rtab{padding:14px 20px;font-size:13px;font-weight:600;color:#666;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;}
.rtab:hover{color:#0d1f3c;}
.rtab.act{color:#0d1f3c;border-bottom-color:#e8c84a;background:#fff;}
.res-main{display:grid;grid-template-columns:1fr 300px;gap:0;align-items:start;max-width:1200px;margin:0 auto;}
.res-content{padding:36px 2rem;}
.res-panel{display:none;}
.res-panel.act{display:block;}
.sec-lbl{color:#e8c84a;font-size:10px;letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;font-weight:700;display:block;}
.res-content h2{color:#0d1f3c;font-size:22px;font-family:Georgia,serif;margin-bottom:20px;line-height:1.3;}
/* DOCS */
.docs-list{display:flex;flex-direction:column;gap:12px;}
.doc-item{display:flex;gap:16px;align-items:center;padding:16px;border:1px solid #dde;border-radius:4px;border-left:4px solid #1a3a6b;}
.doc-item:hover{background:#f8f9fc;}
.doc-icon{width:44px;height:44px;background:#e8f0ff;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.doc-icon svg{width:22px;height:22px;stroke:#1a3a6b;fill:none;stroke-width:1.5;}
.doc-icon.pdf{background:#ffe8e8;}
.doc-icon.pdf svg{stroke:#c8201a;}
.doc-info{flex:1;}
.doc-info h4{color:#0d1f3c;font-size:13px;font-weight:700;margin-bottom:3px;}
.doc-info p{color:#888;font-size:11px;margin:0;}
.doc-actions{display:flex;gap:8px;align-items:center;}
.doc-btn{background:#1a3a6b;color:#fff;border:none;padding:6px 12px;font-size:11px;font-weight:700;border-radius:3px;cursor:pointer;display:flex;align-items:center;gap:4px;text-decoration:none;}
.doc-btn svg{width:11px;height:11px;stroke:#fff;fill:none;stroke-width:2;}
.doc-btn:hover{background:#0d1f3c;color:#fff;}
.doc-share{color:#e8c84a;font-size:11px;font-weight:700;text-decoration:none;border-bottom:1px solid #e8c84a;white-space:nowrap;}
.no-docs{text-align:center;padding:32px;background:#f8f9fc;border-radius:4px;border:1px dashed #dde;}
.no-docs p{color:#888;font-size:13px;}
/* OPINION list style */
.opinion-list{display:flex;flex-direction:column;gap:0;}
.op-item{display:flex;gap:20px;padding:20px 0;border-bottom:1px solid #eee;align-items:flex-start;}
.op-item:last-child{border-bottom:none;}
.op-img{width:100px;height:72px;flex-shrink:0;background:#0d1f3c;border-radius:4px;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.op-img img{width:100%;height:100%;object-fit:cover;}
.op-body{flex:1;}
.op-cat{color:#e8c84a;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;}
.op-body h3{color:#0d1f3c;font-size:14px;font-weight:700;margin-bottom:5px;font-family:Georgia,serif;line-height:1.3;}
.op-body h3 a{color:#0d1f3c;text-decoration:none;}
.op-body h3 a:hover{color:#e8c84a;}
.op-body p{color:#555;font-size:12px;line-height:1.7;margin-bottom:8px;}
.op-footer{display:flex;align-items:center;gap:16px;}
.op-date{color:#999;font-size:11px;}
.read-more{color:#1a3a6b;font-size:12px;font-weight:700;text-decoration:none;border-bottom:1px solid #1a3a6b;margin-left:auto;}
/* SIDEBAR */
.res-sidebar{background:#f8f9fc;border-left:1px solid #dde;padding:28px 18px;display:flex;flex-direction:column;gap:18px;align-self:start;position:sticky;top:70px;}
.sb-card{background:#fff;border:1px solid #dde;border-radius:4px;border-top:3px solid #e8c84a;padding:18px;}
.sb-card h4{color:#0d1f3c;font-size:13px;font-weight:700;margin-bottom:8px;font-family:Georgia,serif;}
.sb-card p{color:#666;font-size:11px;line-height:1.6;margin-bottom:10px;}
.sb-btn{display:block;background:#1a3a6b;color:#fff;text-align:center;padding:9px;font-size:12px;font-weight:700;border-radius:3px;cursor:pointer;border:none;width:100%;margin-bottom:8px;text-decoration:none;}
.sb-btn:hover{background:#0d1f3c;color:#fff;}
.sb-btn.gold{background:#e8c84a;}
.sb-btn.gold:hover{background:#e8b820;}
.sb-links{display:flex;flex-direction:column;gap:6px;}
.sb-link{display:flex;align-items:center;gap:8px;color:#0d1f3c;font-size:12px;text-decoration:none;padding:6px 0;border-bottom:.5px solid #eee;}
.sb-link:hover{color:#e8c84a;}
.sb-link:last-child{border-bottom:none;}
.sb-link svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0;}
.sb-501{background:#0d1f3c;color:#fff;border-radius:4px;padding:14px;text-align:center;}
.sb-501 .badge-501{font-size:16px;font-weight:700;color:#e8c84a;font-family:Georgia,serif;display:block;margin-bottom:3px;}
.sb-501 p{color:#a0b8d8;font-size:11px;margin:0;}
@@media(max-width:767px){.res-main{grid-template-columns:1fr;}.res-sidebar{border-left:none;border-top:1px solid #dde;position:static;}.tab-nav{overflow-x:auto;flex-wrap:nowrap;}.rtab{white-space:nowrap;}}
</style>
}

<!-- PAGE HERO -->
<div class="page-hero-res">
    <div style="max-width:1200px;margin:0 auto;padding:0 1rem;">
        <div class="ph-bc">Home &rsaquo; Resources</div>
        <h1 class="ph-h1">Resources</h1>
        <p class="ph-p">Documents, opinion pieces, press releases and curated links — all shareable via direct URL to social media and email.</p>
    </div>
</div>

<!-- TAB NAVIGATION -->
<div class="tab-nav">
    <div class="rtab act" onclick="showTab('docs')">Documents &amp; Files</div>
    <div class="rtab" onclick="showTab('opinion')">Opinion &amp; Essays</div>
    <div class="rtab" onclick="showTab('press')">Press Releases</div>
    <div class="rtab" onclick="showTab('links')">External Links</div>
</div>

<div class="res-main">
  <div class="res-content">

    <!-- DOCUMENTS & FILES -->
    <div class="res-panel act" id="panel-docs">
        <span class="sec-lbl">Documents &amp; Files</span>
        <h2>Downloadable Documents</h2>
        <p style="color:#555;font-size:13px;line-height:1.8;margin-bottom:20px">All documents below can be downloaded or shared via their direct URL on social media and email.</p>
        @if (!docs.Any())
        {
            <div class="no-docs"><p>No documents available at this time. Check back soon.</p></div>
        }
        else
        {
            <div class="docs-list">
            @foreach (var doc in docs)
            {
                bool isPdf = doc.FileUrl?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ?? false;
                <div class="doc-item">
                    <div class="doc-icon @(isPdf ? "pdf" : "")">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <div class="doc-info">
                        <h4>@doc.Title</h4>
                        <p>@(isPdf ? "PDF" : "Document") @(!string.IsNullOrWhiteSpace(doc.Description) ? "· " + doc.Description : "") · @doc.CreatedAt.ToString("MMMM d, yyyy")</p>
                    </div>
                    <div class="doc-actions">
                        <a class="doc-btn" href="@doc.FileUrl" target="_blank" download>
                            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            Download
                        </a>
                        <a class="doc-share" href="@doc.FileUrl" target="_blank">View</a>
                    </div>
                </div>
            }
            </div>
        }
    </div>

    <!-- OPINION & ESSAYS — redirect to /Opinion -->
    <div class="res-panel" id="panel-opinion">
        <span class="sec-lbl">Opinion &amp; Essays</span>
        <h2>Latest Opinion Pieces &amp; Essays</h2>
        <p style="color:#555;font-size:13px;line-height:1.8;margin-bottom:20px">Read the latest opinion pieces and essays from Communities United for Justice.</p>
        <a href="/Opinion" style="display:inline-block;background:#1a3a6b;color:#fff;padding:10px 24px;border-radius:3px;font-size:13px;font-weight:700;text-decoration:none;">View All Opinion &amp; Essays &rarr;</a>
    </div>

    <!-- PRESS RELEASES -->
    <div class="res-panel" id="panel-press">
        <span class="sec-lbl">Press Releases</span>
        <h2>Press Releases</h2>
        <p style="color:#555;font-size:13px;line-height:1.8;margin-bottom:20px">Official press releases and media statements from Communities United for Justice Fund.</p>
        <div class="no-docs"><p>No press releases available at this time. Check back soon.</p></div>
    </div>

    <!-- EXTERNAL LINKS -->
    <div class="res-panel" id="panel-links">
        <span class="sec-lbl">External Links</span>
        <h2>Curated External Links</h2>
        <p style="color:#555;font-size:13px;line-height:1.8;margin-bottom:20px">Curated resources and external links relevant to our mission.</p>
        <div class="no-docs"><p>No external links available at this time. Check back soon.</p></div>
    </div>

  </div>

  <!-- SIDEBAR -->
  <div class="res-sidebar">
    <div class="sb-card">
        <h4>Resources</h4>
        <p>Navigate our resource sections:</p>
        <div class="sb-links">
            <a class="sb-link" href="#" onclick="showTab('docs');return false;"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Documents &amp; Files</a>
            <a class="sb-link" href="/Opinion"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Opinion &amp; Essays</a>
            <a class="sb-link" href="#" onclick="showTab('press');return false;"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>Press Releases</a>
            <a class="sb-link" href="#" onclick="showTab('links');return false;"><svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>External Links</a>
        </div>
    </div>
    <div class="sb-card">
        <h4>&#10084; Donate Today</h4>
        <p>Support our mission. Your 501(c)(3) donation is fully tax deductible.</p>
        <a href="/GetInvolved#donate" class="sb-btn gold">Donate Now</a>
    </div>
    <div class="sb-card">
        <h4>Get Involved</h4>
        <p>Join the movement. Volunteer, sign up for our newsletter or request a speaker.</p>
        <a href="/GetInvolved" class="sb-btn">Join the Movement</a>
    </div>
    <div class="sb-501">
        <span class="badge-501">501(c)(3)</span>
        <p>Certified Nonprofit Organization<br>Donations are tax deductible</p>
    </div>
  </div>
</div>

@section Scripts {
<script>
function showTab(id) {
    document.querySelectorAll('.res-panel').forEach(p => p.classList.remove('act'));
    document.querySelectorAll('.rtab').forEach(t => t.classList.remove('act'));
    document.getElementById('panel-' + id).classList.add('act');
    const idx = {docs:0,opinion:1,press:2,links:3};
    document.querySelectorAll('.rtab')[idx[id]].classList.add('act');
}
</script>
}
