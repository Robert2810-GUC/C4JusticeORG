<script>
    // Mobile nav toggle
    const toggler = document.getElementById('navToggler');
    const navLinks = document.getElementById('navLinks');
    if (toggler && navLinks) {
        toggler.addEventListener('click', () => {
            const expanded = toggler.getAttribute('aria-expanded') === 'true';
            toggler.setAttribute('aria-expanded', !expanded);
            toggler.classList.toggle('open');
            navLinks.classList.toggle('open');
            const isOpen = navLinks.classList.contains('open');
            // Lock body scroll so page doesn't scroll behind overlay
            document.body.classList.toggle('nav-open', isOpen);
            // Close all open mega menus when closing mobile nav
            if (!isOpen) {
                document.querySelectorAll('.has-mega.open').forEach(o => o.classList.remove('open'));
                navLinks.scrollTop = 0;
            }
        });
    }

    // Sticky nav shadow
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('siteNav');
        if (nav) nav.classList.toggle('scrolled', window.scrollY > 10);
    });

    // Mega menu — hover (desktop) + click toggle (both mobile & desktop)
    document.querySelectorAll('.has-mega').forEach(item => {
        const panel = item.querySelector('.mega-panel');
        if (!panel) return;

        // Desktop: open on hover
        item.addEventListener('mouseenter', () => {
            if (window.innerWidth >= 992) {
                document.querySelectorAll('.has-mega.open').forEach(o => o !== item && o.classList.remove('open'));
                item.classList.add('open');
            }
        });
        item.addEventListener('mouseleave', () => {
            if (window.innerWidth >= 992) item.classList.remove('open');
        });

        // ALL sizes: clicking the top label toggles dropdown, never navigates
        const topLink = item.querySelector(':scope > a');
        if (topLink) {
            // Prevent browser focus (and focus-scroll) on mobile before click fires
            topLink.addEventListener('pointerdown', e => {
                if (window.innerWidth < 992) e.preventDefault();
            });
            topLink.addEventListener('click', e => {
                e.preventDefault();
                e.stopPropagation();
                topLink.blur();
                const alreadyOpen = item.classList.contains('open');
                document.querySelectorAll('.has-mega.open').forEach(o => o.classList.remove('open'));
                if (!alreadyOpen) item.classList.add('open');
            });
        }
    });

    // Close all megas when clicking anywhere outside
    document.addEventListener('click', e => {
        if (!e.target.closest('.has-mega')) {
            document.querySelectorAll('.has-mega.open').forEach(o => o.classList.remove('open'));
        }
    });

    // Prevent mega panel from overflowing off the right edge of the screen
    function fixMegaOverflow() {
        if (window.innerWidth < 992) return;
        document.querySelectorAll('.has-mega').forEach(item => {
            const panel = item.querySelector('.mega-panel');
            if (!panel) return;
            panel.style.left = '0';
            panel.style.right = 'auto';
            const rect = panel.getBoundingClientRect();
            if (rect.right > window.innerWidth - 8) {
                const overflow = rect.right - (window.innerWidth - 8);
                panel.style.left = (-overflow) + 'px';
            }
        });
    }
    document.querySelectorAll('.has-mega').forEach(item => {
        item.addEventListener('mouseenter', () => { setTimeout(fixMegaOverflow, 10); });
        item.addEventListener('click', () => { setTimeout(fixMegaOverflow, 10); });
    });

    // Close mega panel and mobile nav when any link inside a mega panel is clicked
    document.querySelectorAll('.mega-panel a').forEach(link => {
        link.addEventListener('click', () => {
            document.querySelectorAll('.has-mega.open').forEach(o => o.classList.remove('open'));
            navLinks.classList.remove('open');
            toggler.classList.remove('open');
            toggler.setAttribute('aria-expanded', 'false');
            document.body.classList.remove('nav-open');
        });
    });

    // Reliable anchor scroll: fires on page load AND on same-page hash clicks
    function scrollToHash(hash, delay) {
        if (!hash) return;
        const target = document.getElementById(hash.replace('#', ''));
        if (!target) return;
        const stickyNav = document.querySelector('.site-nav') || document.querySelector('nav');
        const offset = (stickyNav ? stickyNav.offsetHeight : 80) + 10;
        setTimeout(() => {
            const y = target.getBoundingClientRect().top + window.pageYOffset - offset;
            window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
        }, delay || 0);
    }

    // Handle hash present on initial page load
    if (location.hash) {
        scrollToHash(location.hash, 120);
    }

    // Handle clicks on anchor links that point to the current page
    document.addEventListener('click', function(e) {
        const a = e.target.closest('a[href*="#"]');
        if (!a) return;
        const href = a.getAttribute('href') || '';
        const hashIdx = href.indexOf('#');
        if (hashIdx === -1) return;
        const path = href.slice(0, hashIdx) || location.pathname;
        const hash = href.slice(hashIdx);
        if (path && path !== location.pathname && path !== window.location.pathname) return;
        const target = document.getElementById(hash.slice(1));
        if (!target) return;
        e.preventDefault();
        history.pushState(null, '', href);
        scrollToHash(hash, 0);
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
@if (_rcEnabled && !string.IsNullOrWhiteSpace(_rcSiteKey) && !_rcSiteKey.StartsWith("YOUR_"))
{
<script src="https://www.google.com/recaptcha/api.js?render=@_rcSiteKey"></script>
<script>
(function(){
    function attachRecaptcha(form) {
        form.addEventListener('submit', function(e) {
            var tokenInput = form.querySelector('input[name="recaptchaToken"]');
            if (!tokenInput) return;
            e.preventDefault();
            grecaptcha.ready(function() {
                grecaptcha.execute('@_rcSiteKey', {action: 'submit'}).then(function(token) {
                    tokenInput.value = token;
                    form.submit();
                });
            });
        });
    }
    document.querySelectorAll('form[data-recaptcha]').forEach(attachRecaptcha);
})();
</script>
}
</body>
</html>
