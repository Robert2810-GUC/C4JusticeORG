<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Communities United for Justice Fund - Fighting for Political, Racial, Economic and Environmental Justice" />
    <title>@ViewData["Title"] - Communities United for Justice</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/c4justice.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ── SITE HEADER ── -->
    <header class="site-header">
        <div class="header-inner">
            <a href="/" class="logo-area">
                <div class="logo-circle">
                    <img src="~/images/c4comlogo.jpg" alt="C4J">                 
                </div>
                <div class="logo-text">
                    <h1>Communities United<br>For Justice Fund</h1>
                    <p>501(c)(3) Nonprofit Organization</p>
                </div>
            </a>
            <div class="header-right">
                <a href="https://www.facebook.com/profile.php?id=61550088064673" target="_blank" rel="noopener" class="fb-icon" title="Follow us on Facebook">
                    <i class="fab fa-facebook-f"></i>
                </a>
            </div>
        </div>
    </header>

    <!-- ── NAVIGATION ── -->
    <nav class="site-nav" id="siteNav">
        <div class="nav-inner">
            <button class="nav-toggler" id="navToggler" aria-label="Toggle navigation" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
            <ul class="nav-links" id="navLinks">
                <li><a href="/" class="@(ViewData["ActivePage"]?.ToString() == "Home" ? "active" : "")">Home</a></li>
                <li><a href="/About" class="@(ViewData["ActivePage"]?.ToString() == "About" ? "active" : "")">About Us</a></li>
                <li class="has-dropdown">
                    <a  class=" cursor-pointer @(ViewData["ActivePage"]?.ToString() is "Issues" or "Opinion" or "Documents" ? "active" : "")">
                        Issues <i class="fas fa-chevron-down ms-1" style="font-size:9px;"></i>
                    </a>
                    <ul class="dropdown-nav">
                        <li><a href="/Issues"><i class="fas fa-bullhorn me-2"></i>Focus Areas</a></li>
                        <li><a href="/Opinion"><i class="fas fa-pen-nib me-2"></i>Opinion / Essays</a></li>
                        <li><a href="/Documents"><i class="fas fa-file-lines me-2"></i>Documents</a></li>
                    </ul>
                </li>
                <li><a href="/Events" class="@(ViewData["ActivePage"]?.ToString() == "Events" ? "active" : "")">Events</a></li>
                <li><a href="/GetInvolved" class="@(ViewData["ActivePage"]?.ToString() == "GetInvolved" ? "active" : "")">Get Involved</a></li>
                <li><a href="/Contact" class="@(ViewData["ActivePage"]?.ToString() == "Contact" ? "active" : "")">Contact</a></li>
            </ul>
            <a href="https://link.clover.com/urlshortener/TscDTq" target="_blank" rel="noopener" class="nav-donate">
                <i class="fas fa-heart me-1"></i> Donate
            </a>
        </div>
    </nav>

    <!-- ── DONATE BAR ── -->
    <div class="donate-bar">
        Donations to the Communities United For Justice Fund 501(c)(3) are tax deductible.
        <a href="https://link.clover.com/urlshortener/TscDTq" target="_blank" rel="noopener">Donate Now &rarr;</a>
    </div>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- ── FOOTER ── -->
    <footer class="site-footer">
        <div class="footer-grid-wrap">
            <div class="footer-col">
                <div class="logo-circle">
                    <img src="~/images/c4comlogo.jpg" alt="C4J">
                </div>
                <h5>Communities United<br>For Justice Fund</h5>
                <p class="footer-tagline">"United We Stand. Divided We Fall."</p>
                <p>A 501(c)(3) social justice advocacy platform fighting for Political, Racial, Economic, and Environmental Justice.</p>
                <div class="footer-social">
                    <a href="https://www.facebook.com/profile.php?id=61550088064673" target="_blank" rel="noopener" class="social-fb" title="Facebook">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                    <a href="mailto:info@cu4justice.com" class="social-em" title="Email">
                        <i class="fas fa-envelope"></i>
                    </a>
                </div>
            </div>

            <div class="footer-col">
                <h5>Quick Links</h5>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/About">About Us</a></li>
                    <li><a href="/Issues">Focus Areas</a></li>
                    <li><a href="/Opinion">Opinion</a></li>
                    <li><a href="/Documents">Documents</a></li>
                    <li><a href="/Events">Events</a></li>
                    <li><a href="/GetInvolved">Get Involved</a></li>
                    <li><a href="/Contact">Contact</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h5>Our Causes</h5>
                <ul>
                    <li><a href="/About#political"><i class="fas fa-landmark me-1"></i> Political Justice</a></li>
                    <li><a href="/About#racial"><i class="fas fa-hands-holding-circle me-1"></i> Racial Justice</a></li>
                    <li><a href="/About#economic"><i class="fas fa-scale-balanced me-1"></i> Economic Justice</a></li>
                    <li><a href="/About#environmental"><i class="fas fa-leaf me-1"></i> Environmental Justice</a></li>
                    <li><a href="/About#healthcare"><i class="fas fa-heart-pulse me-1"></i> Healthcare Justice</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h5>Stay Informed</h5>
                <p>Join our mailing list for updates on events and ways to get involved.</p>
                <form asp-action="Subscribe" asp-controller="Home" method="post">
                    @Html.AntiForgeryToken()
                    <div class="nl-footer-input">
                        <input type="email" name="Email" placeholder="Your email address" required>
                        <input type="hidden" name="Name" value="Newsletter Subscriber">
                        <button type="submit">Subscribe</button>
                    </div>
                </form>
                <a href="https://link.clover.com/urlshortener/TscDTq" target="_blank" rel="noopener" class="donate-footer-btn">
                    <i class="fas fa-heart me-2"></i>Donate to the Fund
                </a>
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; @DateTime.Now.Year Communities United for Justice Fund. All rights reserved.</p>
            <p>A registered 501(c)(3) nonprofit organization.</p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom JS -->
    <script src="~/js/c4justice.js" asp-append-version="true"></script>

    <script>
        // Mobile nav toggle
        const toggler = document.getElementById('navToggler');
        const navLinks = document.getElementById('navLinks');
        if (toggler && navLinks) {
            toggler.addEventListener('click', () => {
                const expanded = toggler.getAttribute('aria-expanded') === 'true';
                toggler.setAttribute('aria-expanded', !expanded);
                navLinks.classList.toggle('open');
            });
        }
        // Sticky nav
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('siteNav');
            if (nav) nav.classList.toggle('scrolled', window.scrollY > 10);
        });
        // Dropdown on hover (desktop) / click (mobile)
        document.querySelectorAll('.has-dropdown').forEach(item => {
            item.addEventListener('mouseenter', () => {
                if (window.innerWidth >= 768) item.classList.add('open');
            });
            item.addEventListener('mouseleave', () => {
                if (window.innerWidth >= 768) item.classList.remove('open');
            });
            const link = item.querySelector('a');
            if (link) link.addEventListener('click', e => {
                if (window.innerWidth < 768) { e.preventDefault(); item.classList.toggle('open'); }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
