<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Communities United for Justice Fund - Fighting for Political, Racial, Economic and Environmental Justice" />
    <title>@ViewData["Title"] - Communities United for Justice</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;600;700;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- AOS Animations -->
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/c4justice.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Preloader -->
    <div id="preloader">
        <div class="preloader-inner">
            <div class="preloader-logo">C4J</div>
            <div class="preloader-bar"><div class="preloader-progress"></div></div>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-c4j fixed-top" id="mainNav">
        <div class="container-xl">
            <a class="navbar-brand" href="/">
                <div class="brand-logo">
                    <img src="~/images/c4orglogo.jpg" alt="C4Justice Logo" class="brand-img"
                         onerror="this.style.display='none'">
                </div>
                <div class="brand-text">
                    <span class="brand-name">Communities United</span>
                    <span class="brand-tagline">for Justice Fund</span>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="toggler-icon">
                    <span></span><span></span><span></span>
                </span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Home" ? "active" : "")" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "About" ? "active" : "")" href="/About">About</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(ViewData["ActivePage"]?.ToString() is "Issues" or "Opinion" or "Documents" ? "active" : "")"
                           href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Issues</a>
                        <ul class="dropdown-menu dropdown-menu-c4j">
                            <li><a class="dropdown-item-c4j" href="/Issues"><i class="fas fa-bullhorn"></i> Focus Areas</a></li>
                            <li><a class="dropdown-item-c4j" href="/Opinion"><i class="fas fa-pen-nib"></i> Opinion / Essays</a></li>
                            <li><a class="dropdown-item-c4j" href="/Documents"><i class="fas fa-file-lines"></i> Documents</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Events" ? "active" : "")" href="/Events">Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Contact" ? "active" : "")" href="/Contact">Contact</a>
                    </li>
                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-donate" href="https://link.clover.com/urlshortener/TscDTq" target="_blank" rel="noopener">
                            <i class="fas fa-heart me-2"></i>Donate
                        </a>
                    </li>
                    <!-- Theme Toggle -->
                    <li class="nav-item ms-2">
                        <button class="theme-toggle-btn" id="themeToggle" aria-label="Toggle light/dark mode" title="Toggle theme">
                            <i class="fas fa-sun theme-icon-light"></i>
                            <i class="fas fa-moon theme-icon-dark"></i>
                        </button>
                    </li>
                    <li class="nav-item ms-1">
                        <a class="nav-social" href="https://www.facebook.com/profile.php?id=61550088064673" target="_blank" rel="noopener" title="Facebook">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-wave">
            <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" class="footer-wave-path"/>
            </svg>
        </div>

        <div class="footer-body">
            <div class="container-xl">
                <div class="row gy-5">
                    <div class="col-lg-4">
                        <div class="footer-brand">
                            <h3 class="footer-brand-name">Communities United<br><span>for Justice Fund</span></h3>
                            <p class="footer-tagline">"United We Stand. Divided We Fall."</p>
                            <p class="footer-desc">A 501(c)(3) social justice advocacy platform fighting for Political, Racial, Economic, and Environmental Justice.</p>
                            <div class="footer-socials">
                                <a href="https://www.facebook.com/profile.php?id=61550088064673" target="_blank" rel="noopener" class="social-btn facebook">
                                    <i class="fab fa-facebook-f"></i>
                                </a>
                                <a href="mailto:info@cu4justice.com" class="social-btn email">
                                    <i class="fas fa-envelope"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-2 col-sm-6">
                        <h5 class="footer-heading">Quick Links</h5>
                        <ul class="footer-links">
                            <li><a href="/"><i class="fas fa-chevron-right"></i> Home</a></li>
                            <li><a href="/About"><i class="fas fa-chevron-right"></i> About Us</a></li>
                            <li><a href="/Issues"><i class="fas fa-chevron-right"></i> Focus Areas</a></li>
                            <li><a href="/Opinion"><i class="fas fa-chevron-right"></i> Opinion</a></li>
                            <li><a href="/Documents"><i class="fas fa-chevron-right"></i> Documents</a></li>
                            <li><a href="/Events"><i class="fas fa-chevron-right"></i> Events</a></li>
                            <li><a href="/Contact"><i class="fas fa-chevron-right"></i> Contact</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-3 col-sm-6">
                        <h5 class="footer-heading">Our Causes</h5>
                        <ul class="footer-links causes">
                            <li><a href="/About#political"><i class="fas fa-landmark"></i> Political Justice</a></li>
                            <li><a href="/About#racial"><i class="fas fa-hands-holding-circle"></i> Racial Justice</a></li>
                            <li><a href="/About#economic"><i class="fas fa-scale-balanced"></i> Economic Justice</a></li>
                            <li><a href="/About#environmental"><i class="fas fa-leaf"></i> Environmental Justice</a></li>
                            <li><a href="/About#healthcare"><i class="fas fa-heart-pulse"></i> Healthcare Justice</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-3">
                        <h5 class="footer-heading">Stay Informed</h5>
                        <p class="footer-newsletter-desc">Join our mailing list for updates on events and ways to get involved.</p>
                        <form asp-action="Subscribe" asp-controller="Home" method="post" class="footer-newsletter-form">
                            @Html.AntiForgeryToken()
                            <div class="newsletter-input-wrap">
                                <input type="email" name="Email" placeholder="Your email address" class="newsletter-input" required>
                                <input type="hidden" name="Name" value="Newsletter Subscriber">
                                <button type="submit" class="newsletter-btn" title="Subscribe">
                                    <i class="fas fa-paper-plane"></i>
                                </button>
                            </div>
                        </form>
                        <div class="footer-donate-cta mt-4">
                            <a href="https://link.clover.com/urlshortener/TscDTq" target="_blank" rel="noopener" class="btn-footer-donate">
                                <i class="fas fa-heart me-2"></i>Donate to the Fund
                            </a>
                            <small class="d-block mt-2 text-muted">Tax-deductible donations to our 501(c)(3)</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="container-xl">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <p class="footer-copy mb-0">&copy; @DateTime.Now.Year Communities United for Justice Fund. All rights reserved.</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p class="footer-tax mb-0">A registered 501(c)(3) nonprofit organization.</p>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AOS -->
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <!-- CountUp.js -->
    <script src="https://cdn.jsdelivr.net/npm/countup.js@2.8.0/dist/countUp.umd.js"></script>
    <!-- Custom JS -->
    <script src="~/js/c4justice.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
