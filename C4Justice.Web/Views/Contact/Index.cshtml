@model C4Justice.Web.Models.ContactViewModel
@inject C4Justice.Web.Data.AppDbContext _settingsDb
@{ var _donateUrl = _settingsDb.SiteSettings.FirstOrDefault(s => s.Key == "zeffy_form_url")?.Value; if (string.IsNullOrWhiteSpace(_donateUrl)) _donateUrl = "@_donateUrl"; }
@{
    ViewData["Title"] = "Contact Us";
    ViewData["ActivePage"] = "Contact";
}

@section Styles {
<style>
.page-hero-contact { background:var(--navy); padding:36px 0; border-bottom:3px solid var(--gold); }
.ph-bc { color:rgba(232,200,74,.7); font-size:11px; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px; }
.ph-h1 { color:#fff; font-size:28px; font-family:var(--font-head); margin-bottom:4px; }
.ph-p  { color:#a0b8d8; font-size:14px; }

/* MAIN LAYOUT — matches site pattern */
.contact-main { display:grid; grid-template-columns:1fr 300px; gap:0; max-width:1400px; margin:0 auto; align-items:start; }

/* MAIN CONTENT — form */
.contact-content { padding:36px 24px; }
.sec-lbl { color:var(--gold); font-size:10px; letter-spacing:2px; text-transform:uppercase; margin-bottom:8px; font-weight:700; display:block; }
.contact-content h2 { color:var(--navy); font-size:22px; font-family:var(--font-head); margin-bottom:8px; }
.contact-content p.intro { color:#555; font-size:14px; line-height:1.85; margin-bottom:24px; }

.cf-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.cf-group { display:flex; flex-direction:column; gap:5px; }
.cf-group.full { grid-column:span 2; }
.cf-group label { color:var(--navy); font-size:13px; font-weight:700; }
.cf-group input, .cf-group select, .cf-group textarea { padding:10px 12px; border:1px solid #dde; border-radius:3px; font-size:14px; color:#333; font-family:var(--font-body); }
.cf-group input:focus, .cf-group select:focus, .cf-group textarea:focus { outline:none; border-color:var(--navy-light); }
.cf-group textarea { min-height:140px; resize:vertical; }
.submit-btn-c { background:var(--navy-light); color:#fff; border:none; padding:12px 32px; font-size:14px; font-weight:700; border-radius:3px; cursor:pointer; margin-top:12px; width:100%; }
.submit-btn-c:hover { background:var(--navy); }
.success-msg { background:#e8f5e8; border:1px solid #1a7a1a; border-radius:4px; padding:20px; text-align:center; margin-bottom:16px; }
.success-msg h3 { color:#0a5a0a; font-size:16px; margin-bottom:6px; font-family:var(--font-head); }
.success-msg p { color:#1a5a1a; font-size:14px; }

/* SIDEBAR */
.contact-sidebar { background:#f8f9fc; border-left:1px solid #dde; padding:28px 18px; display:flex; flex-direction:column; gap:18px; position:sticky; top:70px; align-self:start; }
.sb-card { background:#fff; border:1px solid #dde; border-radius:4px; border-top:3px solid var(--gold); padding:18px; }
.sb-card h4 { color:var(--navy); font-size:13px; font-weight:700; margin-bottom:10px; font-family:var(--font-head); }
.sb-btn { display:block; background:var(--navy-light); color:#fff; text-align:center; padding:9px; font-size:12px; font-weight:700; border-radius:3px; cursor:pointer; border:none; width:100%; text-decoration:none; }
.sb-btn.gold { background:var(--gold); color:var(--navy); }
.sb-btn:hover { background:var(--navy); color:#fff; text-decoration:none; }
.sb-btn.gold:hover { background:#e8b820; color:var(--navy); }

/* Contact info rows in sidebar */
.ci-row { display:flex; gap:10px; align-items:flex-start; margin-bottom:12px; }
.ci-row:last-child { margin-bottom:0; }
.ci-icon-sm { width:32px; height:32px; border-radius:50%; background:rgba(232,200,74,.15); border:1px solid rgba(232,200,74,.3); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.ci-icon-sm svg { width:14px; height:14px; stroke:var(--navy-light); fill:none; stroke-width:1.5; }
.ci-row h5 { color:var(--navy); font-size:11px; font-weight:700; margin-bottom:2px; }
.ci-row p, .ci-row a { color:#666; font-size:11px; line-height:1.5; margin:0; text-decoration:none; display:block; }
.ci-row a:hover { color:var(--navy-light); }

.sb-501 { background:var(--navy); color:#fff; border-radius:4px; padding:14px; text-align:center; }
.sb-501 .badge-501 { font-size:16px; font-weight:700; color:var(--gold); font-family:var(--font-head); display:block; margin-bottom:3px; }
.sb-501 p { color:#a0b8d8; font-size:11px; margin:0; }

@@media(max-width:767px) {
    .contact-main { grid-template-columns:1fr; }
    .contact-sidebar { border-left:none; border-top:1px solid #dde; position:static; }
    .cf-grid { grid-template-columns:1fr; }
    .cf-group.full { grid-column:span 1; }
}
</style>
}

<!-- PAGE HERO -->
<div class="page-hero-contact">
    <div style="max-width:1400px;margin:0 auto;padding:0 24px;">
        <div class="ph-bc">Home &rsaquo; Contact Us</div>
        <h1 class="ph-h1">Contact Us</h1>
        <p class="ph-p">We'd love to hear from you. Get in touch with Communities United For Justice Fund.</p>
    </div>
</div>

<!-- MAIN CONTENT + SIDEBAR -->
<div class="contact-main">

  <!-- FORM — main content -->
  <div class="contact-content">
    <div class="scroll-anchor" id="mailing-list"></div>
    <span class="sec-lbl">Send Us a Message</span>
    <h2>Get In Touch</h2>
    <p class="intro">Fill out the form below and a member of our team will respond within 2 business days.</p>

    @if (TempData["ContactSuccess"] != null)
    {
        <div class="success-msg">
            <h3>Message Sent!</h3>
            <p>@TempData["ContactSuccess"]</p>
        </div>
    }

    <form asp-action="Index" method="post" data-recaptcha>
        @Html.AntiForgeryToken()
        <input type="hidden" name="recaptchaToken" value="" />
        <div class="cf-grid">
            <div class="cf-group full">
                <label asp-for="Name">Full Name *</label>
                <input asp-for="Name" placeholder="Your Full Name" />
                <span asp-validation-for="Name" class="text-danger" style="font-size:11px;"></span>
            </div>
            <div class="cf-group">
                <label asp-for="Email">Email Address *</label>
                <input asp-for="Email" type="email" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-danger" style="font-size:11px;"></span>
            </div>
            <div class="cf-group">
                <label>Phone Number</label>
                <input type="tel" name="Phone" placeholder="(404) 555-0100" />
            </div>
            <div class="cf-group full">
                <label asp-for="Subject">Subject *</label>
                <select asp-for="Subject">
                    <option value="">Select a Subject</option>
                    <option>General Inquiry</option>
                    <option>Volunteer Opportunities</option>
                    <option>Speaker Request</option>
                    <option>Donation Information</option>
                    <option>Media &amp; Press</option>
                    <option>Partnership Inquiry</option>
                    <option>Other</option>
                </select>
            </div>
            <div class="cf-group full">
                <label asp-for="Message">Message *</label>
                <textarea asp-for="Message" placeholder="How can we help you?"></textarea>
                <span asp-validation-for="Message" class="text-danger" style="font-size:11px;"></span>
            </div>
        </div>
        <button type="submit" class="submit-btn-c">Send Message</button>
    </form>
  </div>

  <!-- SIDEBAR — contact info -->
  <div class="contact-sidebar">

    <!-- Contact Details -->
    <div class="sb-card">
        <h4>Contact Information</h4>
        <div class="ci-row">
            <div class="ci-icon-sm"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
            <div><h5>Address</h5><p>East Point, Georgia 30344<br>United States</p></div>
        </div>
        <div class="ci-row">
            <div class="ci-icon-sm"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <div><h5>Email</h5><a href="mailto:info@cu4justice.org">info@cu4justice.org</a></div>
        </div>
        <div class="ci-row">
            <div class="ci-icon-sm"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg></div>
            <div><h5>Phone</h5><a href="tel:4047680001">(404) 768-0001</a></div>
        </div>
        <div class="ci-row">
            <div class="ci-icon-sm"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div><h5>Office Hours</h5><p>Mon – Fri: 9:00 AM – 5:00 PM EST<br>Saturday: By Appointment</p></div>
        </div>
    </div>

    <!-- Donate -->
    <div class="sb-card">
        <h4>&#10084; Donate Today</h4>
        <p style="color:#666;font-size:12px;line-height:1.65;margin-bottom:10px;">Support our mission. Your 501(c)(3) donation is fully tax deductible.</p>
        <a href="@_donateUrl" target="_blank" rel="noopener" class="sb-btn gold">&#10084; Donate Now</a>
    </div>

    <!-- Get Involved -->
    <div class="sb-card">
        <h4>Get Involved</h4>
        <a href="/GetInvolved#volunteer" class="sb-btn" style="margin-bottom:6px;">Volunteer With Us</a>
        <a href="/GetInvolved#newsletter" class="sb-btn" style="margin-top:6px;">Join Mailing List</a>
    </div>

    <!-- 501(c)(3) badge -->
    <div class="sb-501">
        <span class="badge-501">501(c)(3)</span>
        <p>Certified Nonprofit Organization<br>Donations are tax deductible</p>
    </div>

  </div>
</div>
