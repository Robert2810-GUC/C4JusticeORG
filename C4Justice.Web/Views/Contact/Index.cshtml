@model C4Justice.Web.Models.ContactViewModel
@{
    ViewData["Title"] = "Contact Us";
    ViewData["ActivePage"] = "Contact";
}

@section Styles {
<style>
.page-hero-contact { background:#0d1f3c; padding:28px 2rem; border-bottom:3px solid #e8c84a; }
.ph-bc { color:rgba(232,200,74,.7); font-size:11px; letter-spacing:1px; text-transform:uppercase; margin-bottom:6px; }
.ph-h1 { color:#fff; font-size:28px; font-family:Georgia,serif; margin-bottom:4px; }
.ph-p { color:#a0b8d8; font-size:13px; }
.contact-main { display:grid; grid-template-columns:1fr 1fr; gap:0; align-items:start; }
.contact-info { background:#1a2a50; padding:48px 2rem; min-height:500px; }
.ci-label { color:#e8c84a; font-size:10px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px; font-weight:700; display:block; }
.ci-h2 { color:#fff; font-size:24px; font-family:Georgia,serif; margin-bottom:16px; line-height:1.3; }
.ci-p { color:#8898c0; font-size:13px; line-height:1.8; margin-bottom:28px; }
.ci-items { display:flex; flex-direction:column; gap:20px; margin-bottom:32px; }
.ci-item { display:flex; gap:16px; align-items:flex-start; }
.ci-icon { width:42px; height:42px; border-radius:50%; background:rgba(232,200,74,.15); border:1px solid rgba(232,200,74,.3); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.ci-icon svg { width:20px; height:20px; stroke:#e8c84a; fill:none; stroke-width:1.5; }
.ci-text h4 { color:#fff; font-size:13px; font-weight:700; margin-bottom:3px; }
.ci-text p { color:#8898c0; font-size:12px; line-height:1.6; margin:0; }
.ci-text a { color:#e8c84a; text-decoration:none; font-size:12px; }
.social-row { display:flex; gap:12px; margin-top:8px; }
.soc-btn { background:rgba(255,255,255,.08); color:#fff; border:1px solid rgba(255,255,255,.15); padding:8px 16px; font-size:12px; font-weight:700; border-radius:3px; cursor:pointer; display:flex; align-items:center; gap:6px; }
.soc-btn svg { width:14px; height:14px; stroke:#fff; fill:none; stroke-width:2; }
.soc-btn:hover { background:rgba(232,200,74,.2); border-color:#e8c84a; color:#e8c84a; }
.contact-form-wrap { padding:48px 2rem; background:#fff; }
.sec-lbl-c { color:#e8c84a; font-size:10px; letter-spacing:2px; text-transform:uppercase; margin-bottom:8px; font-weight:700; display:block; }
.cf-h2 { color:#0d1f3c; font-size:24px; font-family:Georgia,serif; margin-bottom:8px; }
.cf-p { color:#555; font-size:13px; line-height:1.8; margin-bottom:24px; }
.cf-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.cf-group { display:flex; flex-direction:column; gap:5px; }
.cf-group.full { grid-column:span 2; }
.cf-group label { color:#0d1f3c; font-size:12px; font-weight:700; }
.cf-group input, .cf-group select, .cf-group textarea { padding:10px 12px; border:1px solid #dde; border-radius:3px; font-size:13px; color:#333; font-family:inherit; }
.cf-group input:focus, .cf-group select:focus, .cf-group textarea:focus { outline:none; border-color:#1a3a6b; }
.cf-group textarea { min-height:120px; resize:vertical; }
.submit-btn-c { background:#1a3a6b; color:#fff; border:none; padding:12px 32px; font-size:13px; font-weight:700; border-radius:3px; cursor:pointer; margin-top:12px; width:100%; }
.submit-btn-c:hover { background:#0d1f3c; }
.success-msg { background:#e8f5e8; border:1px solid #1a7a1a; border-radius:4px; padding:20px; text-align:center; margin-bottom:16px; }
.success-msg h3 { color:#0a5a0a; font-size:16px; margin-bottom:6px; font-family:Georgia,serif; }
.success-msg p { color:#1a5a1a; font-size:13px; }
@@media(max-width:767px){ .contact-main{grid-template-columns:1fr;} .cf-grid{grid-template-columns:1fr;} .cf-group.full{grid-column:span 1;} }
</style>
}

<!-- PAGE HERO -->
<div class="page-hero-contact">
    <div style="max-width:1200px;margin:0 auto;padding:0 1rem;">
        <div class="ph-bc">Home &rsaquo; Contact Us</div>
        <h1 class="ph-h1">Contact Us</h1>
        <p class="ph-p">We'd love to hear from you. Get in touch with Communities United For Justice Fund.</p>
    </div>
</div>

<div class="contact-main">
  <!-- LEFT — CONTACT INFO -->
  <div class="contact-info">
    <span class="ci-label">Get In Touch</span>
    <h2 class="ci-h2">We'd Love to Hear From You</h2>
    <p class="ci-p">Whether you have a question about our mission, want to get involved, or just want to say hello — we're here for you. Reach out and a member of our team will respond within 2 business days.</p>
    <div class="ci-items">
      <div class="ci-item">
        <div class="ci-icon"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div>
        <div class="ci-text"><h4>Address</h4><p>East Point, Georgia 30344<br>United States</p></div>
      </div>
      <div class="ci-item">
        <div class="ci-icon"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
        <div class="ci-text"><h4>Email</h4><a href="mailto:info@cu4justice.org">info@cu4justice.org</a></div>
      </div>
      <div class="ci-item">
        <div class="ci-icon"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg></div>
        <div class="ci-text"><h4>Phone</h4><a href="tel:4047680001">(404) 768-0001</a></div>
      </div>
      <div class="ci-item">
        <div class="ci-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <div class="ci-text"><h4>Office Hours</h4><p>Monday – Friday: 9:00 AM – 5:00 PM EST<br>Saturday: By Appointment</p></div>
      </div>
    </div>
    <span class="ci-label">Follow Us</span>
    <div class="social-row">
      <button class="soc-btn"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>Facebook</button>
    </div>
  </div>

  <!-- RIGHT — CONTACT FORM -->
  <div class="contact-form-wrap">
    <span class="sec-lbl-c">Send Us a Message</span>
    <h2 class="cf-h2">Contact Us</h2>
    <p class="cf-p">Fill out the form below and we'll get back to you within 2 business days.</p>

    @if (TempData["ContactSuccess"] != null)
    {
        <div class="success-msg">
            <h3>Message Sent!</h3>
            <p>@TempData["ContactSuccess"]</p>
        </div>
    }

    <form asp-action="Index" method="post">
        @Html.AntiForgeryToken()
        <div class="cf-grid">
            <div class="cf-group full">
                <label asp-for="Name">Full Name *</label>
                <input asp-for="Name" placeholder="Your Full Name" />
                <span asp-validation-for="Name" class="text-danger" style="font-size:11px;"></span>
            </div>
            <div class="cf-group">
                <label asp-for="Email">Email Address *</label>
                <input asp-for="Email" type="email" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-danger" style="font-size:11px;"></span>
            </div>
            <div class="cf-group">
                <label>Phone Number</label>
                <input type="tel" name="Phone" placeholder="(404) 555-0100" />
            </div>
            <div class="cf-group full">
                <label asp-for="Subject">Subject *</label>
                <select asp-for="Subject">
                    <option value="">Select a Subject</option>
                    <option>General Inquiry</option>
                    <option>Volunteer Opportunities</option>
                    <option>Speaker Request</option>
                    <option>Donation Information</option>
                    <option>Media &amp; Press</option>
                    <option>Partnership Inquiry</option>
                    <option>Other</option>
                </select>
            </div>
            <div class="cf-group full">
                <label asp-for="Message">Message *</label>
                <textarea asp-for="Message" placeholder="How can we help you?"></textarea>
                <span asp-validation-for="Message" class="text-danger" style="font-size:11px;"></span>
            </div>
        </div>
        <button type="submit" class="submit-btn-c">Send Message</button>
    </form>
  </div>
</div>
